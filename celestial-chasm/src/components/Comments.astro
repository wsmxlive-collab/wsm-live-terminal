---
interface Props {
  channels?: string; 
  defaultTitle?: string;
}

const { channels = "live-terminal-discussions", defaultTitle = "Live Market Terminal Feed" } = Astro.props;

// Securely read the shortname on the server side using the Cloudflare Pages runtime context
const cloudflareEnv = Astro.locals.runtime?.env;
const rawShortname = cloudflareEnv?.DISQUS_SHORTNAME || import.meta.env.DISQUS_SHORTNAME || "wsmx-live";

// Obfuscate it here on the server so it is never printed as clear text in the client HTML markup
const encryptedShortname = Buffer.from(rawShortname).toString('base64');

const channelList = channels.split(',').map(c => c.trim());
---

<div class="mt-4 pt-4 border-t border-gray-700 w-full">
  <div class="flex flex-wrap items-center justify-between pb-2 mb-2 gap-4">
    <div class="flex flex-col gap-1.5 w-full sm:w-auto">
      <h3 class="text-xs font-semibold text-gray-400 font-mono tracking-wider uppercase">
        {defaultTitle}
      </h3>
      <div class="text-[10px] text-amber-400 font-mono flex flex-col gap-0.5 bg-amber-950/20 p-2 rounded border border-amber-900/30 max-w-xl">
        <span class="font-bold flex items-center gap-1 text-amber-500">
          ⚡ Quick Anonymous Posting:
        </span>
        <span>1. Click the "Name" field inside the chat box below.</span>
        <span>2. Check the checkbox: <span class="text-white underline">"I'd rather post as a guest"</span>.</span>
        <span>3. Pick any nickname and enter email (e.g., <span class="text-white font-bold">anon@live.com</span>). <span class="text-amber-500 font-bold">No verification required!</span></span>
      </div>
    </div>
    
    <div class="flex bg-[#0c1017] p-0.5 rounded border border-gray-800 items-center px-2.5 py-1 gap-2 self-start sm:self-center">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-[11px] font-bold font-mono text-gray-200 uppercase tracking-wide">
        💬 Discussions Live
      </span>
    </div>
  </div>

  <div id="disqus_thread" class="w-full bg-[#070b12] p-4 rounded-lg border border-gray-800 min-h-[300px]"></div>
</div>

<script is:inline define:vars={{ encryptedShortname, channelList }}>
  (function() {
    let activeChannel = channelList[0];

    // Decode the server-passed obfuscated identifier in local script memory scope only
    function getShortname() {
      try {
        return atob(encryptedShortname);
      } catch (e) {
        return "wsmx-live";
      }
    }

    function getCleanUrl(channel) {
      const base = window.location.origin + window.location.pathname;
      return base.replace(/\/$/, '') + '?channel=' + channel;
    }

    function executeDisqusFrame() {
      const box = document.getElementById('disqus_thread');
      if (box) box.innerHTML = '';

      const targetShortname = getShortname();

      if (window.DISQUS) {
        window.DISQUS.reset({
          reload: true,
          config: function () {
            this.page.url = getCleanUrl(activeChannel);
            this.page.identifier = 'wsm-live-channel-' + activeChannel;
          }
        });
      } else {
        var d = document, s = d.createElement('script');
        s.src = 'https://' + targetShortname + '.disqus.com/embed.js';
        s.setAttribute('data-timestamp', +new Date());
        s.async = true;
        (d.head || d.body).appendChild(s);
      }
    }

    if (document.readyState === 'complete') {
      executeDisqusFrame();
    } else {
      window.addEventListener('load', executeDisqusFrame);
    }
  })();
</script>