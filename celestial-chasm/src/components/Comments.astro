---
interface Props {
  channels?: string; 
  defaultTitle?: string;
}

// Fixed hardcoded array sync for the custom channel identifier routing
const { 
  channels = "crypto, gold-silver, oil-gas, usa-market, nifty", 
  defaultTitle = "Live Market Terminal Feed" 
} = Astro.props;

// Securely read the shortname on the server side using the Cloudflare Pages runtime context
const cloudflareEnv = Astro.locals.runtime?.env;
const rawShortname = cloudflareEnv?.DISQUS_SHORTNAME || import.meta.env.DISQUS_SHORTNAME || "wsmx-live";

// Obfuscate it here on the server so it is never printed as clear text in the client HTML markup
const encryptedShortname = Buffer.from(rawShortname).toString('base64');

const channelList = channels.split(',').map(c => c.trim());
---

<div class="mt-6 pt-4 border-t border-gray-800 w-full text-gray-100">
  <div class="flex flex-col gap-4 pb-4 mb-2">
    
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex flex-col gap-1.5 w-full sm:w-auto">
        <h3 class="text-xs font-bold text-gray-400 font-mono tracking-wider uppercase">
          {defaultTitle}
        </h3>
        <div class="text-[10px] text-amber-400 font-mono flex flex-col gap-1 bg-amber-950/30 p-3 rounded-lg border border-amber-900/40 max-w-xl shadow-inner">
          <span class="font-bold flex items-center gap-1 text-amber-500 text-[11px]">
            ⚡ Quick Anonymous Posting:
          </span>
          <span class="text-gray-300">1. Click the <strong class="text-white">"Name"</strong> field inside the chat box below.</span>
          <span class="text-gray-300">2. Check the box: <span class="text-amber-300 underline font-medium">"I'd rather post as a guest"</span>.</span>
          <span class="text-gray-300">3. Choose any nickname & any fake email (e.g., <span class="text-white font-mono bg-gray-900 px-1 py-0.5 rounded">anon@live.com</span>).</span>
        </div>
      </div>
      
      <div class="flex bg-gray-950 p-1 rounded-lg border border-gray-800 items-center px-3 py-1.5 gap-2 self-start sm:self-center shadow-lg">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-[11px] font-bold font-mono text-emerald-400 uppercase tracking-wider">
          💬 Discussions Live
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:flex md:flex-wrap bg-gray-950 p-1.5 rounded-xl border border-gray-800/80 gap-1.5 w-full shadow-2xl">
      {channelList.map((chan, idx) => (
        <button 
          class={`px-3.5 py-2 text-[11px] font-bold font-mono rounded-lg transition-all duration-200 flex items-center justify-center md:justify-start gap-2 border cursor-pointer disqus-tab-btn w-full md:w-auto ${idx === 0 ? 'bg-blue-600 text-white border-blue-500 shadow-md shadow-blue-600/20' : 'text-gray-400 border-transparent bg-transparent hover:text-white hover:bg-gray-900/60'}`}
          data-channel-id={chan}
        >
          {chan === 'crypto' && (
            <svg class="w-3.5 h-3.5 text-yellow-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="tracking-wide">Crypto Chat</span>
          )}
          
          {chan === 'gold-silver' && (
            <svg class="w-3.5 h-3.5 text-amber-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="tracking-wide">GOLD & Silver</span>
          )}
          
          {chan === 'oil-gas' && (
            <svg class="w-3.5 h-3.5 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
            </svg>
            <span class="tracking-wide">Oil & Gas</span>
          )}
          
          {chan === 'usa-market' && (
            <svg class="w-3.5 h-3.5 text-blue-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span class="tracking-wide">USA Markets</span>
          )}
          
          {chan === 'nifty' && (
            <svg class="w-3.5 h-3.5 text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <span class="tracking-wide">Nifty Index</span>
          )}
        </button>
      ))}
    </div>
  </div>

  <div id="disqus_thread" class="w-full bg-[#070b12] p-4 rounded-xl border border-gray-800 min-h-[380px] text-gray-100 shadow-inner" style="color-scheme: dark !important;"></div>
</div>

<script is:inline define:vars={{ encryptedShortname, channelList }}>
  (function() {
    let activeChannel = channelList[0];

    function getShortname() {
      try {
        return atob(encryptedShortname);
      } catch (e) {
        return "wsmx-live";
      }
    }

    function getCleanUrl(channel) {
      const base = window.location.origin + window.location.pathname;
      return base.replace(/\/$/, '') + '?channel=' + channel;
    }

    function executeDisqusFrame() {
      const box = document.getElementById('disqus_thread');
      if (box) box.innerHTML = '';

      const targetShortname = getShortname();

      if (window.DISQUS) {
        window.DISQUS.reset({
          reload: true,
          config: function () {
            this.page.url = getCleanUrl(activeChannel);
            this.page.identifier = 'wsm-live-channel-' + activeChannel;
          }
        });
      } else {
        var d = document, s = d.createElement('script');
        s.src = 'https://' + targetShortname + '.disqus.com/embed.js';
        s.setAttribute('data-timestamp', +new Date());
        s.async = true;
        (d.head || d.body).appendChild(s);
      }
    }

    if (document.readyState === 'complete') {
      executeDisqusFrame();
    } else {
      window.addEventListener('load', executeDisqusFrame);
    }

    // Dynamic Tab Switching Handler Matrix
    document.querySelectorAll('.disqus-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.disqus-tab-btn').forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white', 'border-blue-500', 'shadow-md', 'shadow-blue-600/20');
          b.classList.add('text-gray-400', 'border-transparent', 'bg-transparent');
        });

        btn.classList.remove('text-gray-400', 'border-transparent', 'bg-transparent');
        btn.classList.add('bg-blue-600', 'text-white', 'border-blue-500', 'shadow-md', 'shadow-blue-600/20');

        activeChannel = btn.getAttribute('data-channel-id');
        executeDisqusFrame();
      });
    });
  })();
</script>