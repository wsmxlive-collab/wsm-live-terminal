---
// FILE: src/components/Comments.astro
interface Props {
  channels?: string;
  defaultTitle?: string;
}

// Kept your exact structural categories so tabs match your original layout perfectly
const {
  channels = "market-discussions, metals, global-macro, usa-dow-nifty50",
  defaultTitle = "Live Market Terminal Feed"
} = Astro.props;

const channelList = channels.split(',').map(c => c.trim());

// Preserved all your original high-fidelity custom SVG paths and customized theme classes
const tabConfig: Record<string, { label: string; icon: string; activeClasses: string; glowClass: string; dotBg: string; pulseBg: string }> = {
  "market-discussions": {
    label: "Crypto Discussions",
    icon: `<svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9 8h4.5a2.5 2.5 0 0 1 0 5H9m0 0h5.5a2.5 2.5 0 0 1 0 5H9M10 6v2m4-2v2m-4 10v2m4-2v2M9 13h5"></path></svg>`,
    activeClasses: "bg-purple-950/40 text-purple-400 border-purple-500/40 font-bold",
    glowClass: "shadow-purple-950/50",
    dotBg: "bg-purple-400",
    pulseBg: "bg-purple-500"
  },
  "metals": {
    label: "Gold & Silver",
    icon: `<svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 19h20M5 19l2-8h10l2 8M8 11l1-4h6l1 4M10 7l.5-3h3l.5 3"></path></svg>`,
    activeClasses: "bg-amber-950/40 text-amber-400 border-amber-500/40 font-bold",
    glowClass: "shadow-amber-950/50",
    dotBg: "bg-amber-400",
    pulseBg: "bg-amber-500"
  },
  "global-macro": {
    label: "Crude Oil & NatGas",
    icon: `<svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-13-7-13S5 10.7 5 15a7 7 0 0 0 7 7z"></path></svg>`,
    activeClasses: "bg-emerald-950/40 text-emerald-400 border-emerald-500/40 font-bold",
    glowClass: "shadow-emerald-950/50",
    dotBg: "bg-emerald-400",
    pulseBg: "bg-emerald-500"
  },
  "usa-dow-nifty50": {
    label: "USA Dow & Nifty 50",
    icon: `<svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"></path><circle cx="18.7" cy="8" r="1"></circle></svg>`,
    activeClasses: "bg-cyan-950/40 text-cyan-400 border-cyan-500/40 font-bold",
    glowClass: "shadow-cyan-950/50",
    dotBg: "bg-cyan-400",
    pulseBg: "bg-cyan-500"
  }
};
---
<div class="mt-4 pt-4 border-t border-gray-700 w-full">
  <div class="flex flex-wrap items-center justify-between pb-2 mb-2 gap-4">
    <div class="flex flex-col gap-1.5 w-full sm:w-auto">
      <h3 class="text-xs font-semibold text-gray-400 font-mono tracking-wider uppercase">
        {defaultTitle}
      </h3>
    </div>
    
    <div class="flex bg-[#0c1017] p-0.5 rounded border border-gray-800 items-center px-2.5 py-1 gap-2 self-start sm:self-center">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-[11px] font-bold font-mono text-gray-200 uppercase tracking-wide">
        💬 Discussions Live
      </span>
    </div>
  </div>

  <!-- Tabs Navigation -->
  <div class="w-full mb-4 overflow-x-auto no-scrollbar border-b border-gray-800/60">
    <div class="flex gap-2 min-w-max pb-2.5" id="giscus_tab_container">
      {channelList.map((channel, index) => {
        const config = tabConfig[channel] || {
          label: channel.replace(/-/g, ' ').replace(/(^\w|\s\w)/g, m => m.toUpperCase()),
          icon: `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
          activeClasses: "bg-blue-950/40 text-blue-400 border-blue-500/40 font-bold",
          glowClass: "shadow-blue-950/50",
          dotBg: "bg-blue-400",
          pulseBg: "bg-blue-500"
        };
        const stateClasses = index === 0
          ? `${config.activeClasses} shadow-sm ${config.glowClass}`
          : "bg-[#0c1017] text-gray-400 border-gray-800/80 hover:text-gray-200 hover:border-gray-700";
        return (
          <button
            data-channel={channel}
            data-active-styles={config.activeClasses}
            data-glow-style={config.glowClass}
            class={`giscus-tab group px-4 py-2 text-xs font-medium font-mono rounded-md transition-all duration-200 border cursor-pointer flex items-center gap-2.5 ${stateClasses}`}
          >
            <span class="flex items-center justify-center opacity-85 transition-opacity duration-200 group-hover:opacity-100 text-current" set:html={config.icon} />
            <span>{config.label}</span>
            <span class={`tab-pulse-dot relative flex h-1.5 w-1.5 transition-all duration-200 ${index === 0 ? 'scale-100 opacity-100' : 'scale-0 opacity-0'}`}>
              <span class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-60 ${config.pulseBg}`}></span>
              <span class={`relative inline-flex rounded-full h-1.5 w-1.5 ${config.dotBg}`}></span>
            </span>
          </button>
        );
      })}
    </div>
  </div>

  <!-- The Content Frame where Giscus Comments load dynamically -->
  <div id="giscus_container" class="w-full bg-[#070b12] p-4 rounded-lg border border-gray-800 min-h-[350px]"></div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline define:vars={{ channelList }}>
  (function() {
    let activeChannel = channelList[0];

    function loadGiscusForChannel(channel) {
      const container = document.getElementById('giscus_container');
      if (!container) return;
      
      container.innerHTML = '';

      const script = document.createElement('script');
      // FIXED: Points accurately to the script file asset instead of root landing domain
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'wsmxlive-collab/wsm-live-terminal');
      script.setAttribute('data-repo-id', 'R_kgDOS_g-3Q');
      script.setAttribute('data-category', 'Announcements');
      script.setAttribute('data-category-id', 'DIC_kwDOS_g-3c4Ckf-9');
      
      // Forces isolated query parameters so tabs track unique datasets
      const cleanPath = window.location.pathname.replace(/\/$/, '');
      script.setAttribute('data-term', `${cleanPath}?channel=${channel}`);
      
      script.setAttribute('data-mapping', 'specific');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'bottom');
      script.setAttribute('data-theme', 'dark_dimmed');
      script.setAttribute('data-lang', 'en');
      script.crossOrigin = 'anonymous';
      script.async = true;

      container.appendChild(script);
    }

    function initTabs() {
      const container = document.getElementById('giscus_tab_container');
      if (!container) return;
      const tabs = container.querySelectorAll('.giscus-tab');
      
      tabs.forEach(tab => {
        tab.addEventListener('click', function() {
          const selectedChannel = this.getAttribute('data-channel');
          if (selectedChannel === activeChannel) return;
          activeChannel = selectedChannel;

          tabs.forEach(t => {
            const activeStylesAttr = t.getAttribute('data-active-styles') || '';
            const activeStyles = activeStylesAttr.split(' ').filter(c => c.trim() !== '');
            const glowStyle = t.getAttribute('data-glow-style') || '';
            if (activeStyles.length) t.classList.remove(...activeStyles);
            if (glowStyle) t.classList.remove('shadow-sm', glowStyle);
            t.classList.add('bg-[#0c1017]', 'text-gray-400', 'border-gray-800/80', 'hover:text-gray-200', 'hover:border-gray-700');
            const dot = t.querySelector('.tab-pulse-dot');
            if (dot) {
              dot.classList.remove('scale-100', 'opacity-100');
              dot.classList.add('scale-0', 'opacity-0');
            }
          });

          const targetActiveStylesAttr = this.getAttribute('data-active-styles') || '';
          const targetActiveStyles = targetActiveStylesAttr.split(' ').filter(c => c.trim() !== '');
          const targetGlowStyle = this.getAttribute('data-glow-style') || '';
          this.classList.remove('bg-[#0c1017]', 'text-gray-400', 'border-gray-800/80', 'hover:text-gray-200', 'hover:border-gray-700');
          if (targetActiveStyles.length) this.classList.add(...targetActiveStyles);
          if (targetGlowStyle) this.classList.add('shadow-sm', targetGlowStyle);

          const activeDot = this.querySelector('.tab-pulse-dot');
          if (activeDot) {
            activeDot.classList.remove('scale-0', 'opacity-0');
            activeDot.classList.add('scale-100', 'opacity-100');
          }

          loadGiscusForChannel(activeChannel);
        });
      });
    }

    if (document.readyState === 'complete') {
      initTabs();
      loadGiscusForChannel(activeChannel);
    } else {
      window.addEventListener('load', () => {
        initTabs();
        loadGiscusForChannel(activeChannel);
      });
    }
  })();
</script>

