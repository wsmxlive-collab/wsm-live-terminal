---
import Layout from '../layouts/Layout.astro';
import Comments from '../components/Comments.astro';
import PremiumNewsGrid from '../components/PremiumNewsGrid.astro';
import { getCollection } from 'astro:content';

// 1. Fetch, catch errors, and sort posts natively
const allPosts = await getCollection('blog').catch(() => []);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 2. Safe Normalization: Formats the slug IDs safely for Windows filesystems
const mappedPosts = sortedPosts.map(post => ({
  ...post,
  slug: post.slug || post.id || "wsm-terminal-post"
}));

// 3. Exact Matching Categories: Filters lists cleanly for Astro v6 components
const usaGainers            = mappedPosts.filter(p => p.data.category === 'usa-top-gainers').slice(0, 7);
const nseGainers            = mappedPosts.filter(p => p.data.category === 'nse-top-gainers').slice(0, 7);
const usaNews               = mappedPosts.filter(p => p.data.category === 'usa-stock-news').slice(0, 7);
const nseNews               = mappedPosts.filter(p => p.data.category === 'nse-stock-news').slice(0, 7);
const usaearningsReviews    = mappedPosts.filter(p => p.data.category === 'usa-earnings-reviews').slice(0, 7);
const indearningsReviews    = mappedPosts.filter(p => p.data.category === 'ind-earnings-reviews').slice(0, 7);
const usaIpos               = mappedPosts.filter(p => p.data.category === 'usa-ipos').slice(0, 7);
const indiaIpos             = mappedPosts.filter(p => p.data.category === 'india-ipos').slice(0, 7);



const affiliateChartId = "B0eRLjZ7";

// Clean list of top USA stock tickers mapped out for clean rendering
const topUsaStocks = ['G', 'MSFT', 'SPCX', 'APL', 'AMZN', 'TSL', 'NVDA'];
---

<!-- FRONTMATTER PIPELINE SCALING EXTRACTION TOOL ANURAG->
<div class="w-full mt-6 grid grid-cols-1 md:grid-cols-2 gap-6 font-mono">
  {['usa-top-gainers', 'nse-top-gainers'].map((catField) => {
    const isUS = catField === 'usa-top-gainers';
    const postFeed = mappedPosts.filter(p => p.data.category === catField).slice(0, 3);
    
    return (
      <div class="bg-gray-950 border border-gray-800/60 p-4 rounded-xl flex flex-col justify-between">
        <div>
          <div class="border-b border-gray-900 pb-2 mb-3 flex justify-between items-center">
            <span class={isUS ? "text-blue-400 font-bold text-xs" : "text-orange-400 font-bold text-xs"}>
              {isUS ? "[SECTION 1] USA MARKET HUB" : "[SECTION 6] NSE INDIA TERMINAL"}
            </span>
            <span class="text-[10px] text-gray-500">({postFeed.length} Live Items)</span>
          </div>
          
          {postFeed.length === 0 ? (
            <div class="text-center py-6 text-gray-600 text-[11px]">
              Waiting for runtime markdown ingestion matrix...
            </div>
          ) : (
            postFeed.map((post) => (
              <div class="py-2 border-b border-gray-900/40 last:border-none">
                <h4 class="text-xs text-gray-200 hover:text-blue-400 transition-colors">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h4>
                <div class="text-[10px] text-gray-500 mt-1">
                  {new Date(post.data.pubDate).toLocaleDateString("en-US")} .. 
                  <a href={`/blog/${post.slug}`} class="text-blue-400 font-bold hover:underline ml-1">show more</a>
                </div>
              </div>
            ))
          )}
        </div>
        <div class="pt-3 mt-4 border-t border-gray-900">
          <a href={`/blog?category=${catField}`} class="text-[10px] text-gray-400 hover:text-blue-400 flex justify-between">
            <span>(...show all posts)</span>
            <span>»</span>
          </a>
        </div>
      </div>
    );
  })}
</div>
<!-- FRONTMATTER PIPELINE SCALING EXTRACTION TOOL -->

