---
import Layout from '../layouts/Layout.astro';
import Comments from '../components/Comments.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// All distinct content category feeds completely restored
const usaGainers = sortedPosts.filter(p => p.data.category === 'usa-top-gainers').slice(0, 7);
const nseGainers = sortedPosts.filter(p => p.data.category === 'nse-top-gainers').slice(0, 7);
const usaNews = sortedPosts.filter(p => p.data.category === 'usa-stock-news').slice(0, 7);
const nseNews = sortedPosts.filter(p => p.data.category === 'nse-stock-news').slice(0, 7);
const earningsReviews = sortedPosts.filter(p => p.data.category === 'earnings-reviews').slice(0, 7);
const usaIpos = sortedPosts.filter(p => p.data.category === 'usa-ipos').slice(0, 7);
const indiaIpos = sortedPosts.filter(p => p.data.category === 'india-ipos').slice(0, 7);

const affiliateChartId = "B0eRLjZ7";

// Clean list of top USA stock tickers mapped out for clean rendering
const topUsaStocks = ['GOOG', 'MSFT', 'SPACEX', 'AAPL', 'AMZN', 'TSLA', 'NVDA', 'INTC', 'PEP', 'PG'];
---

<Layout title="WSM Live — Ultimate Multi-Grid Trading Terminal">
  
  <div class="w-full bg-[#0c1017] border-b border-gray-800 min-h-[46px] overflow-hidden mb-4" id="tv-ticker-tape-container"></div>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    
    <div class="bg-gray-900 border border-gray-700 rounded-lg p-3">
      <div class="font-mono text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9h18"></path></svg>
        Global Indices Reference
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 font-mono text-xs font-medium text-gray-300">
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=DJ%3ADJI&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇺🇸</span> Dow Jones 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=CAPITALCOM%3AUS500&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇺🇸</span> S&P 500 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=NASDAQ%3AIXIC&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇺🇸</span> NASDAQ 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=NASDAQ%3AQQQ&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇺🇸</span> QQQ 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=NSE%3ANIFTY&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇮🇳</span> Nifty50 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
        <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=HKEX%3AHSI&utm_source=wsmlive.com`} target="_blank" class="hover:text-blue-400 flex items-center gap-1.5 no-underline text-gray-200">
          <span class="text-base leading-none">🇭🇰</span> HangSeng 
          <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </a>
      </div>
    </div>

    <div class="bg-gray-900 border border-gray-700 rounded-lg p-3">
      <div class="font-mono text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        USA Market Sectors Reference
      </div>
      <div class="flex flex-wrap gap-2 text-xs font-mono">
        {topUsaStocks.map((ticker) => {
          const querySymbol = ticker === 'SPACEX' ? 'PRIVATE:SPACEX' : `NASDAQ:${ticker}`;
          return (
            <a 
              href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=${encodeURIComponent(querySymbol)}&utm_source=wsmlive.com`} 
              target="_blank" 
              class="px-2.5 py-1 bg-[#0c1017] border border-gray-800 rounded text-gray-300 hover:border-blue-400 flex items-center gap-1.5 transition no-underline"
            >
              <span>🇺🇸 {ticker}</span>
              <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Comments identifier="global-macro" defaultTitle="Global Market Discussions" />


  <section class="mt-6 bg-gray-900 border border-gray-700 rounded-lg p-4">
    <h3 class="text-xs font-bold text-amber-400 font-mono uppercase tracking-wider mb-1 flex items-center gap-1.5">
      <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
      The Power Of Holding Early IPO Investments vs. Today
    </h3>
    <p class="text-[11px] font-mono text-gray-400 mb-4">See how a $100 / ₹10,000 early investment in market changed over time:</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
      <div class="bg-[#0c1017] p-3 rounded border border-gray-800">
        <h4 class="text-[11px] font-mono font-bold text-blue-400 border-b border-gray-800 pb-1.5 mb-2">USA Blue-Chips (Base $100 Reference)</h4>
        <div class="space-y-2 text-xs font-mono">
          <div class="flex justify-between text-gray-300"><span>NVDA <span class="text-gray-600">(0.04 Adj Entry)</span></span><span class="text-emerald-400 font-bold">$526,000 Approx</span></div>
          <div class="flex justify-between text-gray-300"><span>TESLA <span class="text-gray-600">(IPO Entry)</span></span><span class="text-emerald-400 font-bold">$148,000 Approx</span></div>
          <div class="flex justify-between text-gray-300"><span>APPLE <span class="text-gray-600">(Historic Base)</span></span><span class="text-emerald-400 font-bold">$389,000 Approx</span></div>
        </div>
      </div>
      <div class="bg-[#0c1017] p-3 rounded border border-gray-800">
        <h4 class="text-[11px] font-mono font-bold text-orange-400 border-b border-gray-800 pb-1.5 mb-2">India Blue-Chips (Base ₹10,000 Reference)</h4>
        <div class="space-y-2 text-xs font-mono">
          <div class="flex justify-between text-gray-300"><span>Reliance Ind <span class="text-gray-600">(Bonus Adjusted)</span></span><span class="text-emerald-400 font-bold">₹2,840,000 Approx</span></div>
          <div class="flex justify-between text-gray-300"><span>Tata Motors <span class="text-gray-600">(Cycle Lows)</span></span><span class="text-emerald-400 font-bold">₹1,120,000 Approx</span></div>
        </div>
      </div>
    </div>
    <Comments identifier="what-if-early" defaultTitle="What If You Invested Early Discussions" />
  </section>

  <section class="mt-6 bg-gray-950 border border-gray-800 rounded-lg p-4 font-mono">
    <div class="border-b border-gray-800 pb-2 mb-3 flex flex-wrap items-center justify-between gap-2">
      <div>
        <h3 class="text-xs font-bold text-emerald-400 uppercase tracking-wider">How much can you safely invest in the Market?</h3>
        <p class="text-[11px] text-gray-500">Enter your monthly income metrics below to find your exact market surplus.</p>
      </div>
      <div>
        <select id="wsm-calc-currency" class="bg-gray-900 border border-gray-700 text-xs text-gray-300 rounded px-2 py-0.5 outline-none font-bold">
          <option value="$">USD ($)</option>
          <option value="₹">INR (₹)</option>
          <option value="£">GBP (£)</option>
        </select>
      </div>
    </div>
    <div class="overflow-x-auto w-full">
      <table class="w-full text-left text-xs min-w-[950px] border border-gray-900">
        <thead>
          <tr class="bg-gray-900 text-gray-400 border-b border-gray-800">
            <th class="p-2 border-r border-gray-800">Salary</th>
            <th class="p-2 border-r border-gray-800">EMI(loans)</th>
            <th class="p-2 border-r border-gray-800">Rent/Housing</th>
            <th class="p-2 border-r border-gray-800">Insurance</th>
            <th class="p-2 border-r border-gray-800">Bills (Water, Elec, Wifi)</th>
            <th class="p-2 border-r border-gray-800">Kids School Fees</th>
            <th class="p-2 border-r border-gray-800">Emergency Fund</th>
            <th class="p-2 border-r border-gray-800">Foods, Groceries</th>
            <th class="p-2 border-r border-gray-800">Fuel & Daily Commute</th>
            <th class="p-2 border-r border-gray-800">Travel | Shopping</th>
            <th class="p-2 bg-blue-950/40 text-blue-400 font-bold">Available to Invest</th>
          </tr>
        </thead>
        <tbody>
          <tr class="bg-[#0c1017] text-gray-200 border-b border-gray-900">
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-salary" class="w-full bg-transparent border-none p-1 outline-none text-emerald-400 font-bold" value="1000" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-emi" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="250" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-rent" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="70" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-ins" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="100" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-bills" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="80" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-fees" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="100" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-emergency" class="w-full bg-transparent border-none p-1 outline-none text-amber-500" value="120" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-food" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="50" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-fuel" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="40" /></td>
            <td class="p-1 border-r border-gray-800"><input type="number" id="inp-shop" class="w-full bg-transparent border-none p-1 outline-none text-red-400" value="40" /></td>
            <td class="p-2 bg-blue-950/20 text-blue-400 font-bold text-center border-none" id="out-investment-net">—</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 bg-gray-900 border border-gray-700 rounded-lg p-4">
    <div>
      <h4 class="text-[11px] font-semibold text-amber-400 font-mono uppercase mb-2 tracking-wide">Earnings Calendar (Global & IN)</h4>
      <div class="w-full h-[260px] bg-[#0c1017] rounded border border-gray-800 overflow-hidden" id="wsm-home-earnings-box"></div>
    </div>
    <div>
      <h4 class="text-[11px] font-semibold text-emerald-400 font-mono uppercase mb-2 tracking-wide">Economic Calendar (FOMC, Inventories)</h4>
      <div class="w-full h-[260px] bg-[#0c1017] rounded border border-gray-800 overflow-hidden" id="wsm-home-economic-box"></div>
    </div>
  </section>

  <section class="bg-gray-900 border border-gray-700 rounded-lg p-4 mt-6">
    <div class="border-b border-gray-800 pb-2 mb-4">
      <h2 class="text-xs font-bold text-gray-200 uppercase tracking-wider font-mono flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        Cryptocurrency Live Stream Terminal
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-[#0c1017] p-3 rounded border border-blue-500/30 bg-blue-950/10 flex flex-col gap-2 live-asset-box" id="box-btc">
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono font-bold text-gray-200">Bitcoin (BTC/USD)</span>
          <button class="live-chart-trigger px-2 py-0.5 text-[10px] font-mono bg-blue-950/60 text-blue-400 rounded border border-blue-800/60 hover:bg-blue-600 hover:text-white transition cursor-pointer flex items-center gap-1" data-symbol="BINANCE:BTCUSDT" data-target="chart-pane-btc" data-parent-box="box-btc">
            View Chart <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
        <div class="tv-price-holder min-h-[32px] flex items-center" data-symbol="BINANCE:BTCUSDT">—</div>
        <div class="w-full h-0 hidden overflow-hidden rounded border border-gray-800 transition-all duration-300" id="chart-pane-btc"></div>
      </div>

      <div class="bg-[#0c1017] p-3 rounded border border-blue-500/30 bg-blue-950/10 flex flex-col gap-2 live-asset-box" id="box-eth">
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono font-bold text-gray-200">Ethereum (ETH/USD)</span>
          <button class="live-chart-trigger px-2 py-0.5 text-[10px] font-mono bg-blue-950/60 text-blue-400 rounded border border-blue-800/60 hover:bg-blue-600 hover:text-white transition cursor-pointer flex items-center gap-1" data-symbol="BINANCE:ETHUSDT" data-target="chart-pane-eth" data-parent-box="box-eth">
            View Chart <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
        <div class="tv-price-holder min-h-[32px] flex items-center" data-symbol="BINANCE:ETHUSDT">—</div>
        <div class="w-full h-0 hidden overflow-hidden rounded border border-gray-800 transition-all duration-300" id="chart-pane-eth"></div>
      </div>
    </div>

    <div class="mt-4 pt-3 border-t border-gray-800 grid grid-cols-1 lg:grid-cols-10 gap-4">
      <div class="lg:col-span-3 font-mono text-[11px]">
        <span class="text-gray-500 font-bold block mb-1">Altcoin Reference Index:</span>
        <div class="grid grid-cols-2 gap-1.5">
          <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=BINANCE:SOLUSDT`} target="_blank" class="p-1 bg-[#0c1017] border border-gray-800 text-gray-400 hover:text-white rounded no-underline block truncate">Solana (SOL) 📺</a>
          <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=BINANCE:XRPUSDT`} target="_blank" class="p-1 bg-[#0c1017] border border-gray-800 text-gray-400 hover:text-white rounded no-underline block truncate">Ripple (XRP) 📺</a>
          <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=BINANCE:BNBUSDT`} target="_blank" class="p-1 bg-[#0c1017] border border-gray-800 text-gray-400 hover:text-white rounded no-underline block truncate">Binance (BNB) 📺</a>
          <a href={`https://www.tradingview.com/chart/${affiliateChartId}/?symbol=BINANCE:ADAUSDT`} target="_blank" class="p-1 bg-[#0c1017] border border-gray-800 text-gray-400 hover:text-white rounded no-underline block truncate">Cardano (ADA) 📺</a>
        </div>
      </div>
      <div class="lg:col-span-7">
        <Comments identifier="crypto-terminal" defaultTitle="Crypto Market Sentiment Boards" />
      </div>
    </div>
  </section>

  <section class="bg-gray-900 border border-gray-700 rounded-lg p-4 mt-6">
    <div class="border-b border-gray-800 pb-2 mb-4">
      <h2 class="text-xs font-bold text-gray-200 uppercase tracking-wider font-mono flex items-center gap-1.5">
        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
        Precious Metals Live Stream Terminal
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-[#0c1017] p-3 rounded border border-blue-500/30 bg-blue-950/10 flex flex-col gap-2 live-asset-box" id="box-gold">
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono font-bold text-gray-200">Gold Spot (XAU/USD)</span>
          <button class="live-chart-trigger px-2 py-0.5 text-[10px] font-mono bg-blue-950/60 text-blue-400 rounded border border-blue-800/60 hover:bg-blue-600 hover:text-white transition cursor-pointer flex items-center gap-1" data-symbol="TVC:GOLD" data-target="chart-pane-gold" data-parent-box="box-gold">
            View Chart <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
        <div class="tv-price-holder min-h-[32px] flex items-center" data-symbol="TVC:GOLD">—</div>
        <div class="w-full h-0 hidden overflow-hidden rounded border border-gray-800 transition-all duration-300" id="chart-pane-gold"></div>
      </div>

      <div class="bg-[#0c1017] p-3 rounded border border-blue-500/30 bg-blue-950/10 flex flex-col gap-2 live-asset-box" id="box-silver">
