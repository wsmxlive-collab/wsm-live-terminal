<script is:inline>
  // Budget Surplus Matrix Processing Engine
  function calculateWSMNet() {
    const salary = parseFloat(document.getElementById('inp-salary')?.value) || 0;
    const emi = parseFloat(document.getElementById('inp-emi')?.value) || 0;
    const rent = parseFloat(document.getElementById('inp-rent')?.value) || 0;
    const ins = parseFloat(document.getElementById('inp-ins')?.value) || 0;
    const bills = parseFloat(document.getElementById('inp-bills')?.value) || 0;
    const fees = parseFloat(document.getElementById('inp-fees')?.value) || 0;
    const emergency = parseFloat(document.getElementById('inp-emergency')?.value) || 0;
    const food = parseFloat(document.getElementById('inp-food')?.value) || 0;
    const fuel = parseFloat(document.getElementById('inp-fuel')?.value) || 0;
    const shop = parseFloat(document.getElementById('inp-shop')?.value) || 0;

    const currency = document.getElementById('wsm-calc-currency')?.value || '$';
    const totalDeductions = emi + rent + ins + bills + fees + emergency + food + fuel + shop;
    const balance = salary - totalDeductions;

    const netOut = document.getElementById('out-investment-net');
    if (netOut) {
      if (balance >= 0) {
        netOut.className = "p-2 bg-emerald-950/40 text-emerald-400 font-bold text-center border-none transition";
        netOut.innerText = `${currency} ${balance.toLocaleString()}`;
      } else {
        netOut.className = "p-2 bg-red-950/40 text-red-400 font-bold text-center border-none transition";
        netOut.innerText = `${currency} ${balance.toLocaleString()} (Deficit)`;
      }
    }
  }

  // Bind Calculation Elements
  ['inp-salary','inp-emi','inp-rent','inp-ins','inp-bills','inp-fees','inp-emergency','inp-food','inp-fuel','inp-shop','wsm-calc-currency'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculateWSMNet);
    document.getElementById(id)?.addEventListener('change', calculateWSMNet);
  });

  // Dynamic Widget Initialization Blocks
  document.addEventListener('DOMContentLoaded', () => {
    calculateWSMNet();

    // 1. Ticker Tape Feed Injection
    if (document.getElementById('tv-ticker-tape-container')) {
      const script = document.createElement('script');
      script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js';
      script.async = true;
      script.innerHTML = JSON.stringify({
        "symbols": [
          {"proName": "FOREXCOM:SPXUSD", "title": "S&P 500 Index"},
          {"proName": "FOREXCOM:NSXUSD", "title": "US Tech 100"},
          {"proName": "FX_IDC:INRUSD", "title": "USD to INR"},
          {"proName": "BITSTAMP:BTCUSD", "title": "Bitcoin"},
          {"proName": "BITSTAMP:ETHUSD", "title": "Ethereum"}
        ],
        "showSymbolLogo": true,
        "colorTheme": "dark",
        "isTransparent": true,
        "displayMode": "adaptive",
        "locale": "en"
      });
      document.getElementById('tv-ticker-tape-container').appendChild(script);
    }

    // 2. Earnings Stream Injection
    if (document.getElementById('wsm-home-earnings-box')) {
      const eScript = document.createElement('script');
      eScript.src = 'https://s3.tradingview.com/external-embedding/embed-widget-events.js';
      eScript.async = true;
      eScript.innerHTML = JSON.stringify({
        "colorTheme": "dark",
        "isTransparent": true,
        "width": "100%",
        "height": "100%",
        "locale": "en",
        "importanceFilter": "-1,0,1",
        "currencyFilter": "USD,INR"
      });
      document.getElementById('wsm-home-earnings-box').appendChild(eScript);
    }

    // 3. Macro Economic Stream Injection
    if (document.getElementById('wsm-home-economic-box')) {
      const ecScript = document.createElement('script');
      ecScript.src = 'https://s3.tradingview.com/external-embedding/embed-widget-timeline.js';
      ecScript.async = true;
      ecScript.innerHTML = JSON.stringify({
        "colorTheme": "dark",
        "isTransparent": true,
        "displayMode": "regular",
        "width": "100%",
        "height": "100%",
        "locale": "en",
        "feedMode": "market",
        "market": "crypto"
      });
      document.getElementById('wsm-home-economic-box').appendChild(ecScript);
    }

    // 4. Live SingleQuote Engine Injection (Fixes Crypto & Precious Metals mismatched text prices)
    function renderLivePrices() {
      document.querySelectorAll('.tv-price-holder').forEach(el => {
        const symbol = el.getAttribute('data-symbol');
        if (!symbol || el.children.length > 0) return;
        
        const qScript = document.createElement('script');
        qScript.src = 'https://s3.tradingview.com/external-embedding/embed-widget-single-quote.js';
        qScript.async = true;
        qScript.innerHTML = JSON.stringify({
          "symbol": symbol,
          "width": "100%",
          "colorTheme": "dark",
          "isTransparent": true,
          "locale": "en"
        });
        el.appendChild(qScript);
      });
    }

    (function checkTradingViewAvailability(retries = 0) {
      if (window.TradingView || retries > 10) {
        renderLivePrices();
      } else {
        setTimeout(() => checkTradingViewAvailability(retries + 1), 300);
      }
    })();
  });

  // Dynamic Interactive Chart Overlay Injection Engine
  document.addEventListener('click', (e) => {
    const triggerBtn = e.target.closest('.live-chart-trigger');
    if (!triggerBtn) return;

    const embeddedAssetSymbol = triggerBtn.getAttribute('data-symbol');
    const targetContainerId = triggerBtn.getAttribute('data-target');
    const parentBoxId = triggerBtn.getAttribute('data-parent-box');

    const viewPane = document.getElementById(targetContainerId);
    const parentBox = document.getElementById(parentBoxId);

    if (!viewPane) return;

    if (viewPane.classList.contains('hidden')) {
      viewPane.classList.remove('hidden');
      viewPane.className = "w-full h-[320px] block overflow-hidden rounded border border-blue-500/40 transition-all duration-300 mt-2";
      triggerBtn.innerHTML = 'Close Terminal ✕';

      if (parentBox) {
        parentBox.classList.remove('border-blue-500/30', 'bg-blue-950/10');
        parentBox.classList.add('border-emerald-500/50', 'bg-emerald-950/20');
      }

      if (viewPane.children.length === 0 && window.TradingView) {
        new window.TradingView.widget({
          "autosize": true,
          "symbol": embeddedAssetSymbol,
          "interval": "D",
          "timezone": "Etc/UTC",
          "theme": "dark",
          "style": "1",
          "locale": "en",
          "enable_publishing": false,
          "hide_top_toolbar": false,
          "container_id": targetContainerId
        });
      }
    } else {
      viewPane.classList.add('hidden');
      viewPane.className = "w-full h-0 hidden overflow-hidden rounded border border-gray-800 transition-all duration-300";
      viewPane.innerHTML = '';
      triggerBtn.innerHTML = 'View Chart <svg class="w-3 h-3 inline ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>';
      
      if (parentBox) {
        parentBox.classList.remove('border-emerald-500/50', 'bg-emerald-950/20');
        parentBox.classList.add('border-blue-500/30', 'bg-blue-950/10');
      }
    }
  });
</script>