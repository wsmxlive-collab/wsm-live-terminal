---
import Layout from "../layouts/Layout.astro";
---

<Layout title="WSM Live - Analysis & Blog">
  <h1 class="text-3xl font-bold text-gray-100 mb-6">Analysis & Blog</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Blog Post Card 1 -->
    <article class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <img src="https://via.placeholder.com/400x200" alt="Blog Post Image" class="rounded-md mb-4 w-full aspect-video object-cover" />
      <h2 class="text-xl font-semibold text-gray-100 mb-2">The Future of Algorithmic Trading</h2>
      <p class="text-gray-400 text-sm mb-3">Explore the latest trends and technologies shaping the world of automated trading strategies.</p>
      <a href="#" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
        Read More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </article>

    <!-- Blog Post Card 2 -->
    <article class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <img src="https://via.placeholder.com/400x200" alt="Blog Post Image" class="rounded-md mb-4 w-full aspect-video object-cover" />
      <h2 class="text-xl font-semibold text-gray-100 mb-2">Understanding Market Volatility</h2>
      <p class="text-gray-400 text-sm mb-3">A deep dive into factors influencing market swings and how to navigate them.</p>
      <a href="#" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
        Read More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </article>

    <!-- Blog Post Card 3 -->
    <article class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <img src="https://via.placeholder.com/400x200" alt="Blog Post Image" class="rounded-md mb-4 w-full aspect-video object-cover" />
      <h2 class="text-xl font-semibold text-gray-100 mb-2">Beginner's Guide to Futures Trading</h2>
      <p class="text-gray-400 text-sm mb-3">Start your journey in futures trading with this comprehensive guide for beginners.</p>
      <a href="#" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
        Read More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </article>

    <!-- Blog Post Card 4 -->
    <article class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <img src="https://via.placeholder.com/400x200" alt="Blog Post Image" class="rounded-md mb-4 w-full aspect-video object-cover" />
      <h2 class="text-xl font-semibold text-gray-100 mb-2">Advanced Options Strategies</h2>
      <p class="text-gray-400 text-sm mb-3">Delve into complex options strategies to optimize your trading performance.</p>
      <a href="#" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
        Read More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </article>
  </div>
</Layout>
