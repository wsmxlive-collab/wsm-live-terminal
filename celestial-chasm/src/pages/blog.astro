---
// FILE: \src\pages\blog.astro
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog").catch(() => []);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const mappedPosts = sortedPosts.map(post => ({
  ...post,
  slug: post.slug || post.id.replace(/\.[^/.]+$/, "")
}));

// Setup client route mapping labels
const categoryLabels: Record<string, string> = {
  "usa-top-gainers": "USA Market Top Gainers Radar",
  "nse-top-gainers": "NSE India Top Gainers Radar",
  "usa-stock-news": "USA Equity Intelligence Stream",
  "nse-stock-news": "Indian Corporate Intelligence Wire",
  "usa-ipos": "USA IPO Early-Stage Pipeline",
  "india-ipos": "Indian Primary Markets & Grey Market Index"
};
---
<Layout title="WSM Terminal Feed — Category Archives Matrix">
  <div class="max-w-[1200px] mx-auto py-4 font-mono">
    <!-- Active Route Header Box -->
    <div class="border border-gray-800 bg-[#070a0f] rounded-xl p-6 mb-8 shadow-xl">
      <div class="flex items-center gap-3 mb-2">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-500 animate-pulse"></span>
        <h1 class="text-base font-bold text-gray-100 uppercase tracking-wider" id="archive-title">
          Live Archive Database Directory
        </h1>
      </div>
      <p class="text-xs text-gray-400">
        Parsing Markdown collection parameters dynamically from active workspace frontmatter indexes.
      </p>
    </div>

    <!-- Feed Container List layout -->
    <div class="space-y-4" id="archive-list-container">
      {mappedPosts.map((post) => (
        <article 
          class="border border-gray-800/80 bg-[#0c1017] rounded-xl p-5 hover:border-blue-500/40 transition-all duration-200 hidden shadow-md"
          data-category={post.data.category}
        >
          <div class="flex flex-wrap items-center justify-between gap-2 text-[11px] text-gray-500 mb-2">
            <span class="bg-gray-900 text-gray-400 border border-gray-800 px-2 py-0.5 rounded uppercase font-bold tracking-wide">
              {categoryLabels[post.data.category] || post.data.category}
            </span>
            <span>{new Date(post.data.pubDate).toLocaleDateString("en-US", {year: 'numeric', month: 'short', day: 'numeric'})}</span>
          </div>
          <h2 class="text-sm font-bold text-gray-100 hover:text-blue-400 transition-colors mb-1.5">
            <a href={`/blog/${post.slug}`} class="no-underline text-current">{post.data.title}</a>
          </h2>
          {post.data.description && <p class="text-xs text-gray-400 leading-relaxed max-w-4xl">{post.data.description}</p>}
          <div class="mt-3 pt-3 border-t border-gray-900 flex justify-between items-center">
            <span class="text-[10px] text-gray-600">Author: {post.data.author || "WSM Admin"}</span>
            <a href={`/blog/${post.slug}`} class="text-[11px] font-bold text-blue-400 hover:underline no-underline">
              Access Full Analysis Terminal Report ➔
            </a>
          </div>
        </article>
      ))}

      <!-- Zero Result Fallback Block Box -->
      <div id="empty-state-notice" class="hidden text-center border border-dashed border-gray-800 rounded-xl py-12">
        <span class="text-xs text-gray-500 uppercase tracking-widest font-bold">Zero records returned for query parameter matrix</span>
      </div>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ categoryLabels }}>
  function processActiveArchiveFilter() {
    const urlParams = new URLSearchParams(window.location.search);
    const targetCat = urlParams.get('category');
    const titleHeader = document.getElementById('archive-title');
    const articles = document.querySelectorAll('#archive-list-container article');
    const emptyNotice = document.getElementById('empty-state-notice');
    
    let parsedCount = 0;

    if (targetCat) {
      if (titleHeader && categoryLabels[targetCat]) {
        titleHeader.innerText = `Category Feed Feed: ${categoryLabels[targetCat].toUpperCase()}`;
      }
      articles.forEach(article => {
        if (article.getAttribute('data-category') === targetCat) {
          article.classList.remove('hidden');
          parsedCount++;
        } else {
          article.classList.add('hidden');
        }
      });
    } else {
      if (titleHeader) titleHeader.innerText = "Master Node Database: All Active Analysis Blogs";
      articles.forEach(article => {
        article.classList.remove('hidden');
        parsedCount++;
      });
    }

    if (parsedCount === 0 && emptyNotice) {
      emptyNotice.classList.remove('hidden');
    } else if (emptyNotice) {
      emptyNotice.classList.add('hidden');
    }
  }

  // Execute processing instantly across app viewport initialization 
  processActiveArchiveFilter();
</script>
