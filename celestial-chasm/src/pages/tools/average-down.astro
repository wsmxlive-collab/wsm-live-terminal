---
// FILE: src/pages/tools/average-down.astro
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Average Down Calculator Optimization Grid — WSM Terminal">
  <div class="max-w-4xl mx-auto py-6 font-mono px-4">
    <div class="mb-6">
      <a href="/" class="text-xs text-blue-400 hover:underline no-underline flex items-center gap-1">
        ⎋ Return to Main Asset Desk Operations Terminal
      </a>
    </div>

    <header class="border border-gray-800 bg-[#070a0f] rounded-xl p-6 mb-8 shadow-xl">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2.5 h-2.5 rounded-full bg-cyan-500 animate-pulse"></span>
        <h1 class="text-base font-bold text-gray-100 uppercase tracking-wider">
          Average Down Cost Basis Optimizer
        </h1>
      </div>
      <p class="text-xs text-gray-400">Map out cost boundaries to see your new average break-even point when scaling into market dips.</p>
      <div class="mt-3 flex justify-end">
        <select id="currency-selector" class="bg-[#05080c] border border-gray-800 text-[10px] text-gray-300 rounded px-2.5 py-1 outline-none font-bold">
          <option value="USD">USD ($)</option>
          <option value="INR">INR (₹)</option>
          <option value="GBP">GBP (£)</option>
          <option value="EUR">EUR (€)</option>
        </select>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Input Panel -->
      <div class="bg-[#090d14] border border-gray-800 rounded-xl p-5 space-y-4">
        <h3 class="text-xs font-bold text-cyan-400 uppercase tracking-wide border-b border-gray-800 pb-2">Current Blocks</h3>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[9px] text-gray-500 uppercase font-bold">1st Purchase Price</label>
            <input type="number" id="p1-price" value="120" class="w-full bg-[#05080c] border border-gray-800 rounded px-2 py-1 text-gray-200 text-xs" />
          </div>
          <div>
            <label class="text-[9px] text-gray-500 uppercase font-bold">1st Shares Amount</label>
            <input type="number" id="p1-shares" value="50" class="w-full bg-[#05080c] border border-gray-800 rounded px-2 py-1 text-gray-200 text-xs" />
          </div>
        </div>

        <h3 class="text-xs font-bold text-cyan-400 uppercase tracking-wide border-b border-gray-800 pb-2 pt-2">Secondary Pullback Scaling</h3>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[9px] text-gray-500 uppercase font-bold">2nd Scale Price</label>
            <input type="number" id="p2-price" value="90" class="w-full bg-[#05080c] border border-gray-800 rounded px-2 py-1 text-cyan-400 font-bold text-xs" />
          </div>
          <div>
            <label class="text-[9px] text-gray-500 uppercase font-bold">2nd Shares Amount</label>
            <input type="number" id="p2-shares" value="50" class="w-full bg-[#05080c] border border-gray-800 rounded px-2 py-1 text-cyan-400 font-bold text-xs" />
          </div>
        </div>
      </div>

      <!-- Output Display Block -->
      <div class="bg-[#090d14] border border-gray-800 rounded-xl p-5 flex flex-col justify-between shadow-xl">
        <div class="space-y-4">
          <h3 class="text-xs font-bold text-gray-300 uppercase tracking-wide border-b border-gray-800 pb-2">Optimized Terminal Result</h3>
          
          <div class="bg-[#05080c] border border-gray-900 rounded-xl p-4 text-center mt-2">
            <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Unified Breakeven Cost Basis</span>
            <span id="optimized-avg-display" class="text-3xl font-bold text-cyan-400 tracking-tight">—</span>
          </div>

          <div class="grid grid-cols-2 gap-2 text-center text-xs pt-2">
            <div class="bg-[#05080c] p-2.5 rounded border border-gray-900">
              <span class="text-[9px] text-gray-500 uppercase block font-bold">Total Shares Count</span>
              <span id="total-shares-display" class="font-bold text-gray-200">—</span>
            </div>
            <div class="bg-[#05080c] p-2.5 rounded border border-gray-900">
              <span class="text-[9px] text-gray-500 uppercase block font-bold">Total Cash Deployed</span>
              <span id="total-capital-display" class="font-bold text-gray-200">—</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const currencyRates = { USD: 1, INR: 83.5, GBP: 0.79, EUR: 0.92 };
    const currencySelector = document.getElementById('currency-selector');

    function formatCurrency(value, currency) {
      const rate = currencyRates[currency] || 1;
      const converted = value * rate;
      const currencyCode = currency === 'INR' ? 'INR' : currency === 'GBP' ? 'GBP' : currency === 'EUR' ? 'EUR' : 'USD';
      const locale = currency === 'INR' ? 'en-IN' : 'en-US';
      return new Intl.NumberFormat(locale, { style: 'currency', currency: currencyCode, maximumFractionDigits: 2 }).format(converted);
    }

    function calculateAvg() {
      const currency = currencySelector?.value || 'USD';
      const p1 = parseFloat(document.getElementById('p1-price').value) || 0;
      const s1 = parseFloat(document.getElementById('p1-shares').value) || 0;
      const p2 = parseFloat(document.getElementById('p2-price').value) || 0;
      const s2 = parseFloat(document.getElementById('p2-shares').value) || 0;

      const totalShares = s1 + s2;
      const totalCost = (p1 * s1) + (p2 * s2);
      const unifiedAvg = totalShares > 0 ? (totalCost / totalShares) : 0;

      document.getElementById('optimized-avg-display').innerText = formatCurrency(unifiedAvg, currency);
      document.getElementById('total-shares-display').innerText = totalShares.toLocaleString() + ' Units';
      document.getElementById('total-capital-display').innerText = formatCurrency(totalCost, currency);
    }

    ['p1-price', 'p1-shares', 'p2-price', 'p2-shares'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calculateAvg);
    });
    currencySelector?.addEventListener('change', calculateAvg);
    window.addEventListener('load', calculateAvg);
  </script>
</Layout>
