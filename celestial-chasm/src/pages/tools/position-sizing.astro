---
// FILE: src/pages/tools/position-sizing.astro
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Position Sizing Matrix Calculator — WSM Terminal">
  <div class="max-w-4xl mx-auto py-6 font-mono px-4">
    <!-- Breadcrumb -->
    <div class="mb-6">
      <a href="/" class="text-xs text-blue-400 hover:underline no-underline flex items-center gap-1">
        ⎋ Return to Main Trading Desk Terminal Grid
      </a>
    </div>

    <!-- Header Frame -->
    <header class="border border-gray-800 bg-[#070a0f] rounded-xl p-6 mb-8 shadow-xl">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-500 animate-pulse"></span>
        <h1 class="text-base font-bold text-gray-100 uppercase tracking-wider">
          Position Sizing & Risk Management Desk
        </h1>
      </div>
      <p class="text-xs text-gray-400">
        Calculate optimal unit distribution sizing metrics to prevent excessive portfolio equity drawdowns.
      </p>
      <div class="mt-3 flex justify-end">
        <select id="currency-selector" class="bg-[#05080c] border border-gray-800 text-[10px] text-gray-300 rounded px-2.5 py-1 outline-none font-bold">
          <option value="USD">USD ($)</option>
          <option value="INR">INR (₹)</option>
          <option value="GBP">GBP (£)</option>
          <option value="EUR">EUR (€)</option>
        </select>
      </div>
    </header>

    <!-- Interactive Grid Layout Workspace -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Input Panel -->
      <div class="md:col-span-1 bg-[#090d14] border border-gray-800/80 rounded-xl p-5 space-y-4">
        <h3 class="text-xs font-bold text-blue-400 uppercase tracking-wide border-b border-gray-800 pb-2">Inputs</h3>
        
        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Total Account Balance</label>
          <input type="number" id="account-size" value="10000" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-emerald-400 font-bold focus:border-blue-500 outline-none text-xs" />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Account Risk Max (%)</label>
          <input type="number" id="risk-percent" value="1" step="0.1" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-red-400 font-bold focus:border-blue-500 outline-none text-xs" />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Entry Price</label>
          <input type="number" id="entry-price" value="100" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-gray-200 focus:border-blue-500 outline-none text-xs" />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Stop Loss Price</label>
          <input type="number" id="stop-price" value="95" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-gray-200 focus:border-blue-500 outline-none text-xs" />
        </div>
      </div>

      <!-- Output Panel -->
      <div class="md:col-span-2 bg-[#090d14] border border-gray-800 rounded-xl p-5 flex flex-col justify-between shadow-xl">
        <div class="space-y-4">
          <h3 class="text-xs font-bold text-gray-300 uppercase tracking-wide border-b border-gray-800 pb-2">Risk Allocation Metrics</h3>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-[#05080c] border border-gray-900 rounded p-3 text-center">
              <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Max Capital At Risk</span>
              <span id="risk-amount-display" class="text-sm font-bold text-red-400">—</span>
            </div>
            <div class="bg-[#05080c] border border-gray-900 rounded p-3 text-center">
              <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Risk Per Unit Share</span>
              <span id="risk-per-share-display" class="text-sm font-bold text-amber-400">—</span>
            </div>
          </div>

          <div class="bg-[#05080c] border border-gray-900 rounded-xl p-4 text-center relative overflow-hidden mt-2">
            <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Optimal Position Sizing</span>
            <span id="position-units-display" class="text-2xl font-bold text-emerald-400 tracking-tight">—</span>
            <span class="text-[10px] text-gray-600 block mt-1">Total Shares / Contracts to Purchase</span>
          </div>
        </div>

        <div class="bg-[#05080c] border border-gray-900 rounded p-3 mt-4 flex justify-between items-center text-xs">
          <span class="text-gray-500">Total Capital Investment Value:</span>
          <span id="total-cost-display" class="font-bold text-gray-200">—</span>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const currencyRates = { USD: 1, INR: 83.5, GBP: 0.79, EUR: 0.92 };
    const currencySelector = document.getElementById('currency-selector');

    function formatCurrency(value, currency) {
      const rate = currencyRates[currency] || 1;
      const converted = value * rate;
      const currencyCode = currency === 'INR' ? 'INR' : currency === 'GBP' ? 'GBP' : currency === 'EUR' ? 'EUR' : 'USD';
      const locale = currency === 'INR' ? 'en-IN' : 'en-US';
      return new Intl.NumberFormat(locale, { style: 'currency', currency: currencyCode, maximumFractionDigits: 2 }).format(converted);
    }

    function calculateSize() {
      const currency = currencySelector?.value || 'USD';
      const balance = parseFloat(document.getElementById('account-size')?.value) || 0;
      const riskPct = parseFloat(document.getElementById('risk-percent')?.value) || 0;
      const entry = parseFloat(document.getElementById('entry-price')?.value) || 0;
      const stop = parseFloat(document.getElementById('stop-price')?.value) || 0;

      const maxRiskCash = balance * (riskPct / 100);
      const riskPerShare = Math.abs(entry - stop);
      
      let shares = 0;
      if (riskPerShare > 0) {
        shares = maxRiskCash / riskPerShare;
      }

      const totalCost = shares * entry;

      document.getElementById('risk-amount-display').innerText = formatCurrency(maxRiskCash, currency);
      document.getElementById('risk-per-share-display').innerText = formatCurrency(riskPerShare, currency);
      document.getElementById('position-units-display').innerText = riskPerShare > 0 ? shares.toFixed(2) + ' Units' : '0.00 Units';
      document.getElementById('total-cost-display').innerText = formatCurrency(totalCost, currency);
    }

    ['account-size', 'risk-percent', 'entry-price', 'stop-price'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calculateSize);
    });
    currencySelector?.addEventListener('change', calculateSize);
    window.addEventListener('load', calculateSize);
  </script>
</Layout>
