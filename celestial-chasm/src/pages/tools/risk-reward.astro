---
// FILE: src/pages/tools/risk-reward.astro
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Risk to Reward Calculator Matrix — WSM Terminal">
  <div class="max-w-4xl mx-auto py-6 font-mono px-4">
    <div class="mb-6">
      <a href="/" class="text-xs text-blue-400 hover:underline no-underline flex items-center gap-1">
        ⎋ Return to Main Operational Trading Desk Terminal Grid
      </a>
    </div>

    <header class="border border-gray-800 bg-[#070a0f] rounded-xl p-6 mb-8 shadow-xl">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2.5 h-2.5 rounded-full bg-purple-500 animate-pulse"></span>
        <h1 class="text-base font-bold text-gray-100 uppercase tracking-wider">
          Risk-to-Reward Ratio Analyzer Desk
        </h1>
      </div>
      <p class="text-xs text-gray-400">Validate trade target metrics to ensure positive macro mathematical expectancy outcomes over time.</p>
      <div class="mt-3 flex justify-end">
        <select id="currency-selector" class="bg-[#05080c] border border-gray-800 text-[10px] text-gray-300 rounded px-2.5 py-1 outline-none font-bold">
          <option value="USD">USD ($)</option>
          <option value="INR">INR (₹)</option>
          <option value="GBP">GBP (£)</option>
          <option value="EUR">EUR (€)</option>
        </select>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-[#090d14] border border-gray-800/80 rounded-xl p-5 space-y-4">
        <h3 class="text-xs font-bold text-purple-400 uppercase tracking-wide border-b border-gray-800 pb-2">Parameters</h3>
        
        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Entry Level Coordinate</label>
          <input type="number" id="rr-entry" value="150" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-gray-200 focus:border-purple-500 outline-none text-xs" />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Take Profit Target</label>
          <input type="number" id="rr-target" value="180" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-emerald-400 font-bold focus:border-purple-500 outline-none text-xs" />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-gray-500 uppercase font-bold">Stop Loss Boundary</label>
          <input type="number" id="rr-stop" value="140" class="w-full bg-[#05080c] border border-gray-800 rounded px-2.5 py-1.5 text-red-400 font-bold focus:border-purple-500 outline-none text-xs" />
        </div>
      </div>

      <div class="md:col-span-2 bg-[#090d14] border border-gray-800 rounded-xl p-5 flex flex-col justify-between shadow-xl">
        <div class="space-y-4">
          <h3 class="text-xs font-bold text-gray-300 uppercase tracking-wide border-b border-gray-800 pb-2">Mathematical Multipliers</h3>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-[#05080c] border border-gray-900 rounded p-3 text-center">
              <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Potential Capital Reward</span>
              <span id="gain-points" class="text-sm font-bold text-emerald-400">—</span>
            </div>
            <div class="bg-[#05080c] border border-gray-900 rounded p-3 text-center">
              <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Potential Capital Risk</span>
              <span id="loss-points" class="text-sm font-bold text-red-400">—</span>
            </div>
          </div>

          <div id="ratio-banner" class="border p-4 rounded-xl text-center mt-2 transition-all">
            <span class="text-[10px] text-gray-500 uppercase block font-bold mb-1">Resulting Risk Ratio</span>
            <span id="rr-ratio-display" class="text-3xl font-bold tracking-tight">—</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const currencyRates = { USD: 1, INR: 83.5, GBP: 0.79, EUR: 0.92 };
    const currencySelector = document.getElementById('currency-selector');

    function formatCurrency(value, currency) {
      const rate = currencyRates[currency] || 1;
      const converted = value * rate;
      const currencyCode = currency === 'INR' ? 'INR' : currency === 'GBP' ? 'GBP' : currency === 'EUR' ? 'EUR' : 'USD';
      const locale = currency === 'INR' ? 'en-IN' : 'en-US';
      return new Intl.NumberFormat(locale, { style: 'currency', currency: currencyCode, maximumFractionDigits: 2 }).format(converted);
    }

    function calculateRR() {
      const currency = currencySelector?.value || 'USD';
      const entry = parseFloat(document.getElementById('rr-entry').value) || 0;
      const target = parseFloat(document.getElementById('rr-target').value) || 0;
      const stop = parseFloat(document.getElementById('rr-stop').value) || 0;

      const gain = target - entry;
      const loss = entry - stop;
      const ratio = loss > 0 ? (gain / loss) : 0;

      document.getElementById('gain-points').innerText = '+' + formatCurrency(gain, currency);
      document.getElementById('loss-points').innerText = '-' + formatCurrency(loss, currency);
      document.getElementById('rr-ratio-display').innerText = '1 : ' + ratio.toFixed(2);

      const banner = document.getElementById('ratio-banner');
      if (ratio >= 2) {
        banner.className = "bg-emerald-950/10 border-emerald-500/30 p-4 rounded-xl text-center mt-2 text-emerald-400 shadow-lg shadow-emerald-950/10";
      } else {
        banner.className = "bg-red-950/10 border-red-500/30 p-4 rounded-xl text-center mt-2 text-red-400 shadow-lg shadow-red-950/10";
      }
    }

    ['rr-entry', 'rr-target', 'rr-stop'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calculateRR);
    });
    currencySelector?.addEventListener('change', calculateRR);
    window.addEventListener('load', calculateRR);
  </script>
</Layout>
