---
// FILE: src/pages/crypto.astro
import Layout from "../layouts/Layout.astro";
import Comments from "../components/Comments.astro"; // 👈 IMPORT YOUR RE-ENGINEERED GISCUS SYSTEM
---
<Layout title="WSM Live - Crypto Terminal">
  <h1 class="text-3xl font-bold text-gray-100 mb-6">Cryptocurrency Terminal</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start mb-12">
    <!-- Bitcoin (BTC/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="BITFINEX:BTCUSD">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Bitcoin (BTC/USD)</h2>
          <div id="btc-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="BINANCE:BTCUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-btc"></div>
    </div>

    <!-- Ethereum (ETH/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="BITFINEX:ETHUSD">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Ethereum (ETH/USD)</h2>
          <div id="eth-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="BINANCE:BTCUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-eth"></div>
    </div>
    <!-- Solana (SOL/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="BINANCE:SOLUSDT">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Solana (SOL/USD)</h2>
          <div id="sol-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="BINANCE:SOLUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-sol"></div>
    </div>

    <!-- Litecoin (LTC/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="BINANCE:LTCUSDT">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Litecoin (LTC/USD)</h2>
          <div id="ltc-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="BINANCE:LTCUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-ltc"></div>
    </div>

    <!-- Dogecoin (DOGE/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="BINANCE:DOGEUSDT">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Dogecoin (DOGE/USD)</h2>
          <div id="doge-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="BINANCE:DOGEUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-doge"></div>
    </div>

    <!-- Trumpcoin (TRUMP/USD) Asset Card Block -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg asset-card" data-ticker="MEXC:TRUMPUSDT">
      <div class="flex items-center justify-between gap-4 w-full border-b border-gray-800 pb-3">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <h2 class="text-lg font-semibold text-gray-100 whitespace-nowrap">Trumpcoin (TRUMP/USD)</h2>
          <div id="trump-price" class="price-holder min-w-[120px] h-[32px] flex items-center" data-symbol="MEXC:TRUMPUSDT">—</div>
        </div>
        <button class="chart-toggle-btn p-2 rounded border border-blue-500/30 bg-blue-950/40 text-blue-400 hover:bg-blue-600 hover:text-white transition-all flex-shrink-0" title="Toggle Chart">
          <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </button>
      </div>
      <div class="chart-container hidden w-full h-[360px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-trump"></div>
    </div>
  </div>

  <!-- FIXED & REPLACED DISQUS CONTAINER BLOCK: WIRED TO HIGH-PERFORMANCE MULTI-TAB GISCUS COMPONENT -->
  <div class="bg-[#090d14] border border-gray-800 rounded-xl p-4 sm:p-6 shadow-xl mt-8">
    <Comments 
      channels="market-discussions, metals, global-macro, usa-dow-nifty50" 
      defaultTitle="Crypto Terminal Intelligence Streams" 
    />
  </div>

  <script is:inline>
    // Pure Dynamic Inline TradingView Chart Toggle Engine
    const cryptoCards = document.querySelectorAll('.asset-card');
    cryptoCards.forEach(card => {
      const toggleButton = card.querySelector('.chart-toggle-btn');
      const graphicBox = card.querySelector('.chart-container');
      const dataTickerFeed = card.getAttribute('data-ticker');
      const targetElementId = graphicBox ? graphicBox.getAttribute('id') : null;
      if (!toggleButton || !graphicBox || !targetElementId) return;

      toggleButton.addEventListener('click', () => {
        const isCurrentlyHidden = graphicBox.classList.contains('hidden');
        if (isCurrentlyHidden) {
          graphicBox.classList.remove('hidden');
          toggleButton.classList.remove('border-blue-500/30', 'bg-blue-950/40', 'text-blue-400', 'hover:bg-blue-600');
          toggleButton.classList.add('border-emerald-500/40', 'bg-emerald-950/60', 'text-emerald-400', 'hover:bg-emerald-600');
          if (window.TradingView && dataTickerFeed && targetElementId && graphicBox.children.length === 0) {
            new window.TradingView.widget({
              "width": "100%",
              "height": "100%",
              "symbol": dataTickerFeed,
              "interval": "D",
              "timezone": "Etc/UTC",
              "theme": "dark",
              "style": "1",
              "locale": "en",
              "container_id": targetElementId,
              "aff_id": "167679"
            });
          }
        } else {
          graphicBox.classList.add('hidden');
          graphicBox.innerHTML = '';
          toggleButton.classList.remove('border-emerald-500/40', 'bg-emerald-950/60', 'text-emerald-400', 'hover:bg-emerald-600');
          toggleButton.classList.add('border-blue-500/30', 'bg-blue-950/40', 'text-blue-400', 'hover:bg-blue-600');
        }
      });
    });

    function renderSmallPrices() {
      const mapping = [
        { id: 'btc-price', symbol: 'BINANCE:BTCUSDT' },
        { id: 'eth-price', symbol: 'BINANCE:ETHUSDT' },
        { id: 'sol-price', symbol: 'BINANCE:SOLUSDT' },
        { id: 'ltc-price', symbol: 'BINANCE:LTCUSDT' },
        { id: 'doge-price', symbol: 'BINANCE:DOGEUSDT' },
        { id: 'trump-price', symbol: 'MEXC:TRUMPUSDT' }
      ];
      mapping.forEach(item => {
        const el = document.getElementById(item.id);
        if (!el || el._rendered) return;
        if (window.TradingView && window.TradingView.SingleQuoteWidget) {
          try {
            new window.TradingView.SingleQuoteWidget({
              symbol: item.symbol,
              width: "100%",
              colorTheme: "dark",
              isTransparent: true,
              locale: "en",
              container_id: item.id
            });
            el._rendered = true;
          } catch (err) {
            el.textContent = '';
          }
        }
      });
    }

    const formatPrice = (p) => typeof p === 'number' ? p.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 4 }) : p;

    (function waitAndFillFallback(retries = 0) {
      if (window.TradingView && window.TradingView.SingleQuoteWidget) return;
      const needs = [
        { id: 'btc-price', symbol: 'BINANCE:BTCUSDT' },
        { id: 'eth-price', symbol: 'BINANCE:ETHUSDT' },
        { id: 'sol-price', symbol: 'BINANCE:SOLUSDT' },
        { id: 'ltc-price', symbol: 'BINANCE:LTCUSDT' },
        { id: 'doge-price', symbol: 'BINANCE:DOGEUSDT' },
        { id: 'trump-price', symbol: 'MEXC:TRUMPUSDT' }
      ];
      needs.forEach(async (m) => {
        const el = document.getElementById(m.id);
        if (!el) return;
        try {
          if (m.symbol.startsWith('BINANCE:')) {
            const s = m.symbol.split(':')[1];
            const res = await fetch(`https://binance.com{encodeURIComponent(s)}`);
            if (res.ok) {
              const j = await res.json();
              if (j && j.price) { el.textContent = formatPrice(Number(j.price)); return; }
            }
          }
          const res = await fetch(`/api/price?symbol=${encodeURIComponent(m.symbol)}`);
          if (res.ok) {
            const j = await res.json();
            if (j && j.price) el.textContent = formatPrice(j.price);
          }
        } catch (e) {
          el.textContent = 'N/A';
        }
      });
      if (retries < 20) setTimeout(() => waitAndFillFallback(retries + 1), 500);
    })();

    (function waitAndRenderPrices(retries = 0) {
      if (window.TradingView && window.TradingView.SingleQuoteWidget) {
        renderSmallPrices();
      } else if (retries < 30) {
        setTimeout(() => waitAndRenderPrices(retries + 1), 300);
      }
    })();
  </script>
</Layout>
