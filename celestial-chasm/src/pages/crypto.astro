---
import Layout from "../layouts/Layout.astro";
---

<Layout title="WSM Live - Crypto Terminal">
  <h1 class="text-3xl font-bold text-gray-100 mb-6">Cryptocurrency Terminal</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Bitcoin Card -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <h2 class="text-xl font-semibold text-gray-100 mb-1">Bitcoin (BTC/USD)</h2>
      <div id="btc-price" class="text-emerald-400 text-sm font-medium mb-2">—</div>
      <p class="text-gray-400 mb-4">Real-time price, volume, and market cap for Bitcoin.</p>
      <button class="chart-toggle-btn inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" data-chart-id="btc-chart">
        + View Live Chart
      </button>
      <div id="btc-chart" class="tradingview-widget-container hidden mt-4 rounded-md overflow-hidden h-[360px]">
        <div id="btc-embed" style="width:100%;height:100%;"></div>
      </div>
    </div>

    <!-- Ethereum Card -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <h2 class="text-xl font-semibold text-gray-100 mb-1">Ethereum (ETH/USD)</h2>
      <div id="eth-price" class="text-emerald-400 text-sm font-medium mb-2">—</div>
      <p class="text-gray-400 mb-4">Real-time price, volume, and market cap for Ethereum.</p>
      <button class="chart-toggle-btn inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" data-chart-id="eth-chart">
        + View Live Chart
      </button>
      <div id="eth-chart" class="tradingview-widget-container hidden mt-4 rounded-md overflow-hidden h-[360px]">
        <div id="eth-embed" style="width:100%;height:100%;"></div>
      </div>
    </div>

    <!-- Altcoins Overview Card -->
    <div class="bg-gray-900 rounded-lg p-5 border border-gray-700 shadow-lg">
      <h2 class="text-xl font-semibold text-gray-100 mb-1">Altcoins Overview</h2>
      <div id="alt-price" class="text-emerald-400 text-sm font-medium mb-2">—</div>
      <p class="text-gray-400 mb-4">Track top altcoins and their market performance.</p>
      <button class="chart-toggle-btn inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" data-chart-id="altcoins-chart">
        + View Live Chart
      </button>
      <div id="altcoins-chart" class="tradingview-widget-container hidden mt-4 rounded-md overflow-hidden h-[360px]">
        <div id="altcoins-embed" style="width:100%;height:100%;"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const toggleButtons = document.querySelectorAll(".chart-toggle-btn");

      toggleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const chartId = button.dataset.chartId;
          const chartContainer = document.getElementById(chartId);

          if (chartContainer) {
            const isHidden = chartContainer.classList.contains("hidden");
            chartContainer.classList.toggle("hidden", !isHidden);
            button.textContent = isHidden ? "- Minimize" : "+ View Live Chart";
          }
        });
      });
    });
  </script>

  <script is:inline>
    // Inject TradingView external-embedding widgets when a chart is first shown
    function injectChart(containerId, symbol) {
      const container = document.getElementById(containerId);
      if (!container) return;
      if (container._injected) return;
      const script = document.createElement('script');
      script.type = 'text/javascript';
      script.src = 'https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js';
      script.async = true;
      script.innerHTML = JSON.stringify({
        "symbol": symbol,
        "interval": "D",
        "timezone": "Etc/UTC",
        "theme": "dark",
        "style": "1",
        "locale": "en",
        "toolbar_bg": "#111827",
        "enable_publishing": false,
        "allow_symbol_change": true,
        "hide_side_toolbar": false,
        "details": true,
        "studies": [],
        "width": "100%",
        "height": "100%",
        "aff_id": "167679"
      });
      container.appendChild(script);
      container._injected = true;
    }

    // Listen for toggles and inject appropriate widget on first reveal
    document.addEventListener('click', (e) => {
      const btn = e.target.closest && e.target.closest('.chart-toggle-btn');
      if (!btn) return;
      const chartId = btn.dataset.chartId;
      if (chartId === 'btc-chart') injectChart('btc-embed', 'BITFINEX:BTCUSD');
      if (chartId === 'eth-chart') injectChart('eth-embed', 'BITFINEX:ETHUSD');
      if (chartId === 'altcoins-chart') injectChart('altcoins-embed', 'BINANCE:SOLUSDT');
    });

    // Render small live price widgets below titles using TradingView SingleQuoteWidget
    function renderSmallPrices() {
      const mapping = [
        // Use Binance REST-friendly pairs for client-side fallback (CORS allowed)
        { id: 'btc-price', symbol: 'BINANCE:BTCUSDT' },
        { id: 'eth-price', symbol: 'BINANCE:ETHUSDT' },
        { id: 'alt-price', symbol: 'BINANCE:SOLUSDT' }
      ];

      mapping.forEach(item => {
        const el = document.getElementById(item.id);
        if (!el) return;
        if (el._rendered) return;
        // Create a lightweight single quote widget if available
        if (window.TradingView && window.TradingView.SingleQuoteWidget) {
          try {
            // @ts-ignore
            new window.TradingView.SingleQuoteWidget({
              symbol: item.symbol,
              width: "100%",
              colorTheme: "dark",
              isTransparent: true,
              locale: "en",
              container_id: item.id
            });
            el._rendered = true;
          } catch (err) {
            // fallback: fetch price via iframe-less link
            el.textContent = '';
          }
        }
      });
    }

    async function fetchPriceForSymbol(symbolStr) {
      if (!symbolStr) return null;
      if (symbolStr.startsWith('BINANCE:')) {
        const s = symbolStr.split(':')[1];
        try {
          const res = await fetch(`https://api.binance.com/api/v3/ticker/price?symbol=${encodeURIComponent(s)}`);
          if (!res.ok) return null;
          const j = await res.json();
          return Number(j.price);
        } catch (e) { return null; }
      }
      if (symbolStr.startsWith('BITFINEX:')) {
        const pair = symbolStr.split(':')[1];
        const apiSym = 't' + pair.replace('/', '');
        try {
          const res = await fetch(`https://api-pub.bitfinex.com/v2/ticker/${apiSym}`);
          if (!res.ok) return null;
          const j = await res.json();
          return Number(j[6]);
        } catch (e) { return null; }
      }
      return null;
    }

    function formatPrice(num) {
      if (num === null || typeof num === 'undefined' || Number.isNaN(num)) return 'N/A';
      if (num >= 1000) return num.toLocaleString(undefined, { maximumFractionDigits: 2 });
      if (num >= 1) return num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
      return num.toString();
    }

    // If TradingView widgets cannot be used, populate live prices via REST
    (function waitAndFillFallback(retries = 0) {
      const mapping = [
        { id: 'btc-price', symbol: 'BINANCE:BTCUSDT' },
        { id: 'eth-price', symbol: 'BINANCE:ETHUSDT' },
        { id: 'alt-price', symbol: 'BINANCE:SOLUSDT' }
      ];
      const needs = mapping.filter(m => {
        const el = document.getElementById(m.id);
        return el && (!el._rendered && (!el.textContent || el.textContent.trim() === '—' || el.textContent.trim() === '' || el.textContent.trim() === 'N/A'));
      });
      if (needs.length === 0) return;
      if (window.TradingView && window.TradingView.SingleQuoteWidget) return; // widgets will render themselves
      needs.forEach(async (m) => {
        const el = document.getElementById(m.id);
        if (!el) return;
        el.textContent = '…';
        try {
          if (m.symbol.startsWith('BINANCE:')) {
            const s = m.symbol.split(':')[1];
            const res = await fetch(`https://api.binance.com/api/v3/ticker/price?symbol=${encodeURIComponent(s)}`);
            if (!res.ok) { el.textContent = 'N/A'; return; }
            const j = await res.json();
            el.textContent = j && j.price ? formatPrice(Number(j.price)) : 'N/A';
            return;
          }
          // Fallback to server proxy for other providers
          const res = await fetch(`/api/price?symbol=${encodeURIComponent(m.symbol)}`);
          if (!res.ok) { el.textContent = 'N/A'; return; }
          const j = await res.json();
          el.textContent = j && j.price ? formatPrice(j.price) : 'N/A';
        } catch (e) {
          el.textContent = 'N/A';
        }
      });
      if (retries < 20) setTimeout(() => waitAndFillFallback(retries + 1), 500);
    })();

    // Try rendering prices when TradingView core is ready
    (function waitAndRenderPrices(retries = 0) {
      if (window.TradingView && window.TradingView.SingleQuoteWidget) {
        renderSmallPrices();
      } else if (retries < 20) {
        setTimeout(() => waitAndRenderPrices(retries + 1), 200);
      }
    })();
  </script>
</Layout>
