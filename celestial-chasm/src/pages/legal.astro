---
import Layout from "../layouts/Layout.astro";
---

<Layout title="WSM Live - Legal & Support">
  <h1 class="text-3xl font-bold text-gray-100 mb-6">Legal & Support</h1>

  <div class="bg-gray-900 rounded-lg p-6 border border-gray-700 shadow-lg">
    <div class="flex flex-wrap gap-2 border-b border-gray-700 mb-6" role="tablist">
      <button
        class="tab-button px-4 py-2 text-gray-400 font-medium border-b-2 border-transparent hover:text-gray-200 hover:border-blue-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 data-[active=true]:text-gray-200 data-[active=true]:border-blue-600"
        data-tab="privacy"
        aria-controls="privacy-panel"
        role="tab"
        aria-selected="true"
        data-active="true"
      >
        Privacy Policy
      </button>
      <button
        class="tab-button px-4 py-2 text-gray-400 font-medium border-b-2 border-transparent hover:text-gray-200 hover:border-blue-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 data-[active=true]:text-gray-200 data-[active=true]:border-blue-600"
        data-tab="terms"
        aria-controls="terms-panel"
        role="tab"
        aria-selected="false"
      >
        Terms of Service
      </button>
      <button
        class="tab-button px-4 py-2 text-gray-400 font-medium border-b-2 border-transparent hover:text-gray-200 hover:border-blue-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 data-[active=true]:text-gray-200 data-[active=true]:border-blue-600"
        data-tab="disclaimer"
        aria-controls="disclaimer-panel"
        role="tab"
        aria-selected="false"
      >
        Disclaimer
      </button>
      <button
        class="tab-button px-4 py-2 text-gray-400 font-medium border-b-2 border-transparent hover:text-gray-200 hover:border-blue-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 data-[active=true]:text-gray-200 data-[active=true]:border-blue-600"
        data-tab="contact"
        aria-controls="contact-panel"
        role="tab"
        aria-selected="false"
      >
        Contact
      </button>
    </div>

    <!-- Tab Panels -->
    <div id="privacy-panel" role="tabpanel" tabindex="0" class="tab-panel text-gray-300 active" aria-labelledby="privacy-tab">
      <h2 class="text-2xl font-semibold text-gray-100 mb-4">Privacy Policy for WSM Live Terminal</h2>
      <p class="text-sm text-gray-400 mb-4"><strong>Effective Date: July 1, 2026</strong></p>
      <p class="mb-4">At WSM Live Terminal (accessible via wsmlive.com), your privacy is one of our core operational priorities. This Privacy Policy document outlines the specific classifications of data metrics collected, recorded, and handled by our framework systems.</p>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">1. Information We Collect and Process</h3>
      <ul class="list-disc list-inside space-y-2 ml-4 mb-4">
        <li><strong>Log Files:</strong> Like most standard server environments, WSM Live Terminal utilizes system log logs. This data includes internet protocol (IP) addresses, browser classification details, Internet Service Provider (ISP) patterns, time stamps, and exit pages. This information is purely used to evaluate terminal performance and administer site functionality.</li>
        <li><strong>Cookies and Web Beacons:</strong> We utilize cookies to store visitor preferences and optimize user experience based on browser configurations.</li>
      </ul>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">2. Google AdSense & Third-Party Vendor Rules</h3>
      <ul class="list-disc list-inside space-y-2 ml-4 mb-4">
        <li>Google, as a third-party advertising network vendor, uses cookies to serve contextual advertisements across our terminal interfaces.</li>
        <li>Google's use of specialized advertising cookies enables it and its corporate partners to serve ads to our users based on their visits to wsmlive.com and other digital domains across the internet.</li>
        <li>You may choose to decline personalized advertising layouts by visiting the <a href="https://adssettings.google.com" target="_blank" class="text-blue-400 hover:underline">Google Ads Settings portal</a>.</li>
      </ul>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">3. Data Protection Rights</h3>
      <p>You have the right to request access to, correction of, or erasure of any automated analytical logs collected during your active terminal sessions. If you have any inquiries regarding these metrics, reach out directly to our administration grid via: <a href="mailto:contact@wsmlive.com" class="text-blue-400 hover:underline">contact@wsmlive.com</a>.</p>
    </div>

    <div id="terms-panel" role="tabpanel" tabindex="0" class="tab-panel hidden text-gray-300" aria-labelledby="terms-tab">
      <h2 class="text-2xl font-semibold text-gray-100 mb-4">Terms of Service Agreement</h2>
      <p class="text-sm text-gray-400 mb-4"><strong>Last Updated: July 1, 2026</strong></p>
      <p class="mb-4">By accessing and operating the market data grids, calculator scripts, and financial visualization tools hosted at wsmlive.com, you explicitly agree to fulfill and bind your session actions to the operational parameters outlined in this Terms of Service agreement.</p>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">1. User License & Workspace Boundaries</h3>
      <ul class="list-disc list-inside space-y-2 ml-4 mb-4">
        <li>The interactive calculators, mathematical models, and macro-tracking nodes rendered across the WSM Live Terminal layout are provided entirely as free open-access tools for educational research.</li>
        <li>Scraping, copying, or reverse-engineering our processing modules for commercial distribution without explicit written consent from the network administrators is prohibited.</li>
      </ul>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">2. Operational System Boundaries</h3>
      <p>We reserve the complete operational right to adjust, pause, optimize, or terminate any dynamic pricing ticker feeds, custom calculator pages, or user terminal views at any moment without prior notice or liability metrics.</p>
      
      <p class="mt-6 pt-4 border-t border-gray-700 text-sm">For questions regarding these Terms, please contact us at <a href="mailto:admin@wsmlive.com" class="text-blue-400 hover:underline">admin@wsmlive.com</a>.</p>
    </div>

    <div id="disclaimer-panel" role="tabpanel" tabindex="0" class="tab-panel hidden text-gray-300" aria-labelledby="disclaimer-tab">
      <h2 class="text-2xl font-semibold text-gray-100 mb-4">Financial Advice & Operational Liability Disclaimer</h2>
      <p class="text-sm text-gray-400 mb-4 px-3 py-2 bg-amber-950/20 border border-amber-800/40 rounded"><strong>⚠️ IMPORTANT REGULATORY DISCLOSURE NOTICE</strong></p>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">1. No Professional Financial Advice Provided</h3>
      <p class="mb-4">The financial position sizing tools, risk-to-reward matrix calculators, cost basis average-down calculators, intrinsic value DCF projections, and market blog entries displayed across the WSM Live Terminal grid are engineered and published <strong>strictly for informational and educational research purposes only</strong>.</p>
      <p class="mb-4">WSM Live Terminal does not operate as a registered investment advisor, financial broker, or asset management institution. None of the mathematical data models, price projections, or news posts constitute proprietary recommendations to buy, hold, or liquidate any cryptocurrency tokens, equities, choices contracts, or commodities positions.</p>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">2. Mathematical Modeling Risk Acceptance</h3>
      <p class="mb-4">The investment and trading calculations rendered via our client-side modules are approximations derived from historical metrics and user-input parameters. Geometric asset compounding curves and historical IPO growth analytics are not indicative of forward-looking market performance realities.</p>
      
      <h3 class="text-xl font-semibold text-gray-100 mb-3 mt-6">3. Absolute Indemnification</h3>
      <p class="mb-4">You assume full, independent responsibility for all financial risks and actions taken based on calculations generated by our platform tools. WSM Live Terminal, its open-source collaborators, and its master administrators shall not be held liable for any structural capital losses or portfolio drawdowns resulting directly or indirectly from the use of this interface.</p>
      
      <p class="mb-4 px-3 py-2 bg-blue-950/20 border border-blue-800/40 rounded text-sm">Always consult with a certified, licensed financial professional before executing capital allocations inside live financial markets.</p>
    </div>

    <div id="contact-panel" role="tabpanel" tabindex="0" class="tab-panel hidden text-gray-300" aria-labelledby="contact-tab">
      <h2 class="text-2xl font-semibold text-gray-100 mb-4">Contact Us</h2>
      <p class="mb-6">If you have any questions, concerns, or feedback regarding WSM Live Terminal, our legal documents, or any of our services, please reach out to our administration team:</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="bg-[#090d14] border border-gray-800 rounded-lg p-4">
          <h3 class="text-sm font-semibold text-blue-400 mb-2">General Admin Support</h3>
          <a href="mailto:admin@wsmlive.com" class="text-gray-300 hover:text-blue-400 transition">admin@wsmlive.com</a>
        </div>
        
        <div class="bg-[#090d14] border border-gray-800 rounded-lg p-4">
          <h3 class="text-sm font-semibold text-blue-400 mb-2">Customer Support</h3>
          <a href="mailto:support@wsmlive.com" class="text-gray-300 hover:text-blue-400 transition">support@wsmlive.com</a>
        </div>
        
        <div class="bg-[#090d14] border border-gray-800 rounded-lg p-4">
          <h3 class="text-sm font-semibold text-blue-400 mb-2">General Inquiries</h3>
          <a href="mailto:info@wsmlive.com" class="text-gray-300 hover:text-blue-400 transition">info@wsmlive.com</a>
        </div>
        
        <div class="bg-[#090d14] border border-gray-800 rounded-lg p-4">
          <h3 class="text-sm font-semibold text-blue-400 mb-2">Privacy & Legal</h3>
          <a href="mailto:contact@wsmlive.com" class="text-gray-300 hover:text-blue-400 transition">contact@wsmlive.com</a>
        </div>
      </div>
      
      <p class="text-sm text-gray-400">Our support team aims to respond to all inquiries within 24-48 business hours. Thank you for being part of the WSM Live community!</p>
    </div>
  </div>

  <script is:inline>
    const initLegalTabs = () => {
      const tabButtons = document.querySelectorAll(".tab-button");
      const tabPanels = document.querySelectorAll(".tab-panel");

      const setActiveTab = (button) => {
        const targetTab = button.dataset.tab;

        tabButtons.forEach(btn => {
          btn.setAttribute("aria-selected", "false");
          btn.removeAttribute("data-active");
          btn.classList.remove("text-gray-200", "border-blue-600");
          btn.classList.add("text-gray-400");
        });

        tabPanels.forEach(panel => panel.classList.add("hidden"));

        button.setAttribute("aria-selected", "true");
        button.setAttribute("data-active", "true");
        button.classList.remove("text-gray-400");
        button.classList.add("text-gray-200", "border-blue-600");

        document.getElementById(`${targetTab}-panel`)?.classList.remove("hidden");
      };

      tabButtons.forEach(button => {
        button.addEventListener("click", () => setActiveTab(button));
      });

      const initialTab = document.querySelector('.tab-button[data-active="true"]') || document.querySelector('.tab-button[data-tab="privacy"]');
      if (initialTab) {
        setActiveTab(initialTab);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initLegalTabs);
    } else {
      initLegalTabs();
    }
  </script>
</Layout>
