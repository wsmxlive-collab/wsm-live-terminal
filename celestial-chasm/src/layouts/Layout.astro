---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "WSM Live — Multi-Grid Trading Terminal", 
  description = "An ultra-fast Financial Market Screener & Multi-Grid Trading Terminal for global assets: US Equities, Indian Equities, Commodities, and Cryptocurrencies."
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";


const isCryptoActive = currentPath === '/crypto';
const isBlogActive = currentPath === '/blog';
const isLegalActive = currentPath === '/legal';

const navItems = [

  { href: '/crypto', label: 'Crypto Terminal', active: isCryptoActive },
  { href: '/blog', label: 'Analysis & Blog', active: isBlogActive },
  { href: '/legal', label: 'Legal & Support', active: isLegalActive },
];
---

<!doctype html>
<html lang="en" class="bg-[#0c1017]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght=400;600;700&family=JetBrains+Mono:wght=400;700&display=swap" rel="stylesheet">
    
    <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
  </head>
  <body class="bg-[#0c1017] text-gray-200 min-h-screen flex flex-col font-sans antialiased">
    
    <header class="sticky top-0 z-40 bg-[#0c1017]/80 backdrop-blur-md border-b border-gray-700 px-4 py-3 md:px-8 md:py-3">
      <div class="max-w-[1400px] w-full mx-auto flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center justify-between w-full gap-3 md:w-auto">
          <a href="/" class="flex items-center gap-2 no-underline">
            <svg class="w-6 h-6 text-blue-500 fill-current" viewBox="0 0 76 65">
              <path d="M37.5273 0L75.0546 65H0L37.5273 0Z"></path>
            </svg>
            <span class="font-sans font-semibold tracking-tight text-lg text-gray-200">
              WSM <span class="font-mono text-xs font-normal text-gray-400 bg-gray-800 px-1.5 py-0.5 rounded ml-1 border border-gray-700">LIVE</span>
            </span>
          </a>
          <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-mono bg-emerald-950/50 text-emerald-400 border border-emerald-800/60 animate-pulse">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Real-Time
          </span>
        </div>

        <nav class="flex flex-wrap overflow-x-auto whitespace-nowrap gap-2 text-sm font-medium -mx-4 px-4 md:mx-0 md:px-0 w-full md:w-auto" aria-label="Main Navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={item.active ? 'page' : undefined}
              class={`inline-flex shrink-0 no-underline px-3 py-1.5 rounded-full ${item.active
                ? 'text-gray-200 bg-gray-800 border border-gray-700'
                : 'text-gray-400 hover:text-gray-200'}`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-1 w-full max-w-[1400px] mx-auto px-4 md:px-8 py-6 outline-none">
      <slot />
    </main>

    <footer class="w-full bg-[#0c1017] border-t border-gray-700 py-8 px-4 md:px-8 font-mono text-xs text-gray-400">
      <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 items-start text-left">
        
        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-bold text-gray-200 uppercase tracking-wider border-b border-gray-800 pb-1.5">Follow Us on:</h4>
          <div class="flex flex-wrap gap-2">
            <a href="https://youtube.com/@wsmlive" target="_blank" class="px-2.5 py-1 bg-red-950/30 text-red-400 border border-red-900/40 rounded hover:bg-red-600 hover:text-white transition no-underline">YouTube</a>
            <a href="https://facebook.com/wsmlive" target="_blank" class="px-2.5 py-1 bg-blue-950/30 text-blue-400 border border-blue-900/40 rounded hover:bg-blue-600 hover:text-white transition no-underline">Facebook</a>
            <a href="https://instagram.com/wsmlive" target="_blank" class="px-2.5 py-1 bg-pink-950/30 text-pink-400 border border-pink-900/40 rounded hover:bg-pink-600 hover:text-white transition no-underline">Instagram</a>
            <a href="https://reddit.com/r/wsmlive" target="_blank" class="px-2.5 py-1 bg-orange-950/30 text-orange-400 border border-orange-900/40 rounded hover:bg-orange-600 hover:text-white transition no-underline">Reddit</a>
            <a href="https://twitter.com/wsmlive" target="_blank" class="px-2.5 py-1 bg-gray-900/60 text-gray-300 border border-gray-800 rounded hover:bg-white hover:text-black transition w-full text-center no-underline">Twitter / X</a>
          </div>
        </div>

        <div class="md:col-span-2 flex flex-col gap-3">
          <h4 class="text-xs font-bold text-blue-400 uppercase tracking-wider border-b border-gray-800 pb-1.5">WSM Terminal Quick Tools</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <a href="/tools/position-sizing" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Position Sizing Calculator</a>
            <a href="/tools/compound-interest" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Compound Interest Calculator</a>
            <a href="/tools/risk-reward" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Risk to Reward Calculator</a>
            <a href="/tools/dividend-sip" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Dividend & SIP Calculator</a>
            <a href="/tools/average-down" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Average Down Calculator</a>
            <a href="/tools/intrinsic-dcf" class="p-2 bg-[#06080c] border border-gray-800 text-gray-400 hover:text-white rounded transition hover:border-gray-700 no-underline">Intrinsic Value (DCF) Matrix</a>
          </div>
        </div>

      </div>
      <div class="mt-8 pt-4 border-t border-gray-800 text-center text-[10px] text-gray-600">
        © 2026 WSM Live. Watchlist Data Ingestion Matrix Streams via Shared Watchlist ID #335875673.
      </div>
    </footer>

    <script is:inline>
      const normalizePath = (path) => {
        const cleaned = String(path ?? '').trim().replace(/\/+$/g, '');
        return cleaned === '' ? '/' : cleaned;
      };
      const activePath = normalizePath(window.location.pathname);
      document.querySelectorAll('header nav a').forEach((link) => {
        const href = normalizePath(link.getAttribute('href') || '/');
        if (href === activePath) {
          link.classList.remove('text-gray-400', 'hover:text-gray-200');
          link.classList.add('text-gray-200', 'bg-gray-800', 'border', 'border-gray-700');
          link.setAttribute('aria-current', 'page');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import "tailwindcss";
  html, body { 
    background-color: #0c1017 !important; 
    color: #e5e7eb !important; 
    margin: 0;
  }
</style>