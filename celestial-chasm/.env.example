# Copy to .env and fill in keys. DO NOT commit the real .env to git.
# Finnhub (indices, commodities, futures, many exchanges)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Disqus shortname (for comments)
DISQUS_SHORTNAME=your_disqus_shortname_here

# Optional: other provider keys
ALPHA_VANTAGE_KEY=
TWELVEDATA_KEY=

# Note: For Cloudflare Pages, add these as environment variables in the project settings.
