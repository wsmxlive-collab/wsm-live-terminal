---
import Layout from '../layouts/Layout.astro';
import Comments from '../components/Comments.astro';
---

<Layout title="WSM Live — Multi-Grid Trading Terminal">
  <!-- Dynamic Real-Time Ticker Tape Banner -->
  <div class="w-full bg-[#0c1017] border-b border-gray-700 min-h-[40px]" id="tradingview-ticker-tape"></div>

  <!-- Quick Price Summary -->
  <section class="mt-4 w-full bg-[#111827] border border-gray-700 rounded-lg p-4 text-xs text-gray-300">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <div class="font-mono text-emerald-400 uppercase tracking-wider">Live Price Snap</div>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 w-full sm:w-auto">
        <div class="group rounded-md border border-gray-800 bg-[#0c1017] p-2 hover:border-blue-500" title="Bitcoin (BTC/USDT)">
          <div class="text-gray-400 text-[10px] uppercase">BTC</div>
          <div id="summary-price-btc" class="text-emerald-400 font-semibold">...</div>
        </div>
        <div class="group rounded-md border border-gray-800 bg-[#0c1017] p-2 hover:border-blue-500" title="Ethereum (ETH/USDT)">
          <div class="text-gray-400 text-[10px] uppercase">ETH</div>
          <div id="summary-price-eth" class="text-emerald-400 font-semibold">...</div>
        </div>
        <div class="group rounded-md border border-gray-800 bg-[#0c1017] p-2 hover:border-blue-500" title="NIFTY 50 (NSE:NIFTY)">
          <div class="text-gray-400 text-[10px] uppercase">NIFTY</div>
          <div id="summary-price-nifty" class="text-emerald-400 font-semibold">...</div>
        </div>
        <div class="group rounded-md border border-gray-800 bg-[#0c1017] p-2 hover:border-blue-500" title="S&P 500">
          <div class="text-gray-400 text-[10px] uppercase">S&P500</div>
          <div id="summary-price-sp500" class="text-emerald-400 font-semibold">...</div>
        </div>
        <div class="group rounded-md border border-gray-800 bg-[#0c1017] p-2 hover:border-blue-500" title="Dow Jones (TVC:DJI)">
          <div class="text-gray-400 text-[10px] uppercase">DOW</div>
          <div id="summary-price-dow" class="text-emerald-400 font-semibold">...</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CRYPTOWATCH-STYLE DYNAMIC MATRIX REPLICA CONTAINER WORKSPACE -->
  <div id="cryptowatch-dynamic-workspace" class="hidden w-full mt-4 p-4 bg-[#111827] border border-gray-700 rounded-lg">
    <div class="flex justify-between items-center mb-4 border-b border-gray-700 pb-2">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider font-mono">⚡ Cryptowatch Active Multi-Grid Matrix</h2>
      </div>
      <a href="/" class="text-xs text-blue-400 hover:underline no-underline font-semibold bg-gray-800 px-2 py-1 rounded border border-gray-700 font-mono">Reset Dashboard</a>
    </div>
    <div id="dynamic-grid-container" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
  </div>

  <!-- STANDARD CORE FALLBACK WORKSPACE INTERFACE -->
  <main id="wsm-standard-workspace" class="space-y-6 mt-4">
    <!-- SECTION 1: Crypto Market Pulse -->
    <section class="bg-[#111827] border border-gray-700 p-4 rounded-lg">
      <h2 class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider font-mono">[SECTION 1] Crypto Market Pulse</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="BINANCE:BTCUSDT">
          <div>
            <span class="font-bold text-sm block mb-1">Bitcoin (BTC/USDT)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="BINANCE:BTCUSDT"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-btc"></div>
          <Comments identifier="chart-btc" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="BINANCE:ETHUSDT">
          <div>
            <span class="font-bold text-sm block mb-1">Ethereum (ETH/USDT)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="BINANCE:ETHUSDT"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-eth"></div>
          <Comments identifier="chart-eth" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="BINANCE:SOLUSDT">
          <div>
            <span class="font-bold text-sm block mb-1">Solana (SOL/USDT)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="BINANCE:SOLUSDT"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-sol"></div>
          <Comments identifier="chart-sol" />
        </div>
      </div>
    </section>

    <!-- SECTION 2: Precious Metals & Energy Commodities -->
    <section class="bg-[#111827] border border-gray-700 p-4 rounded-lg">
      <h2 class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider font-mono">[SECTION 2] Precious Metals & Energy Commodities</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="TVC:GOLD">
          <div>
            <span class="font-bold text-sm block mb-1">Gold (TVC:GOLD)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="TVC:GOLD"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-gold"></div>
          <Comments identifier="chart-gold" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="TVC:SILVER">
          <div>
            <span class="font-bold text-sm block mb-1">Silver (TVC:SILVER)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="TVC:SILVER"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-silver"></div>
          <Comments identifier="chart-silver" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="COMEX:HG1!">
          <div>
            <span class="font-bold text-sm block mb-1">Copper (COMEX:HG1!)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="COMEX:HG1!"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-copper"></div>
          <Comments identifier="chart-copper" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="NYMEX:CL1!">
          <div>
            <span class="font-bold text-sm block mb-1">Crude Oil (NYMEX:CL1!)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="NYMEX:CL1!"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-crude"></div>
          <Comments identifier="chart-crude" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="NYMEX:NG1!">
          <div>
            <span class="font-bold text-sm block mb-1">Natural Gas (NYMEX:NG1!)</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="NYMEX:NG1!"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-natgas"></div>
          <Comments identifier="chart-natgas" />
        </div>
      </div>
    </section>

    <!-- SECTION 3: Global Indices Monitor -->
    <section class="bg-[#111827] border border-gray-700 p-4 rounded-lg">
      <h2 class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider font-mono">[SECTION 3] Global Indices Monitor</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="NSE:NIFTY">
          <div>
            <span class="font-bold text-sm block mb-1">NIFTY 50</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="NSE:NIFTY"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-nifty-idx"></div>
          <Comments identifier="chart-nifty-idx" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="^GSPC">
          <div>
            <span class="font-bold text-sm block mb-1">S&P 500</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="^GSPC"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-sp500-idx"></div>
          <Comments identifier="chart-sp500-idx" />
          <div class="mt-4">
            <p class="text-gray-400 text-sm">S&P 500 is a stock market index that measures the stock performance of 500 large companies listed on stock exchanges in the United States.</p>
          </div>
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="TVC:DJI">
          <div>
            <span class="font-bold text-sm block mb-1">Dow Jones</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="TVC:DJI"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-dow-idx"></div>
          <Comments identifier="chart-dow-idx" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="^N225">
          <div>
            <span class="font-bold text-sm block mb-1">Nikkei 225</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="^N225"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-nikkei-idx"></div>
          <Comments identifier="chart-nikkei-idx" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="^HSI">
          <div>
            <span class="font-bold text-sm block mb-1">Hang Seng</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="^HSI"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-hangseng-idx"></div>
          <Comments identifier="chart-hangseng-idx" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="^GDAXI">
          <div>
            <span class="font-bold text-sm block mb-1">DAX</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="^GDAXI"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-dax-idx"></div>
          <Comments identifier="chart-dax-idx" />
        </div>

        <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md flex flex-col justify-between asset-card" data-ticker="^FCHI">
          <div>
            <span class="font-bold text-sm block mb-1">CAC 40</span>
            <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="^FCHI"></div>
          </div>
          <button class="chart-toggle-btn w-full text-center text-xs bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded transition">[+ View Inline Chart]</button>
          <div class="chart-container hidden w-full h-[320px] mt-4 rounded border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-cac-idx"></div>
          <Comments identifier="chart-cac-idx" />
        </div>
      </div>
    </section>

    <!-- SECTION 4: Major Index Watchlist & Market Monitor -->
      <!-- LEFT PANEL: WATCHLIST OVERVIEW -->
      <section class="space-y-6 bg-[#111827] border border-gray-700 p-4 rounded-lg">
        <div>
          <h2 class="text-xs font-bold text-gray-400 mb-2 uppercase tracking-wider font-mono">[SECTION 2] Live Watchlist Market Matrix</h2>
          <div class="bg-[#0c1017] rounded border border-gray-700 p-1 min-h-[450px]" id="tradingview-watchlist-matrix"></div>
        </div>
      </section>

      <!-- RIGHT PANEL: CORE INDEX MONITORS -->
      <section class="space-y-6 bg-[#111827] border border-gray-700 p-4 rounded-lg">
        <div>
          <h2 class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider font-mono">[SECTION 3] Major Index Monitor</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md asset-card" data-ticker="NSE:NIFTY">
              <span class="text-sm font-bold block mb-1">NIFTY 50</span>
              <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="NSE:NIFTY"></div>
              <button class="chart-toggle-btn w-full text-xs bg-blue-600 py-1.5 rounded text-white font-sans">[+ View Inline Chart]</button>
              <div class="chart-container hidden h-[360px] mt-3 border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-nifty50"></div>
              <Comments identifier="chart-nifty50" />
            </div>
            <div class="bg-[#0c1017] p-4 border border-gray-700 rounded-md asset-card" data-ticker="TVC:DJI">
              <span class="text-sm font-bold block mb-1">DOW JONES (^DJI)</span>
              <div class="h-[46px] overflow-hidden mb-2 price-holder" data-symbol="TVC:DJI"></div>
              <button class="chart-toggle-btn w-full text-xs bg-blue-600 py-1.5 rounded text-white font-sans">[+ View Inline Chart]</button>
              <div class="chart-container hidden h-[360px] mt-3 border border-gray-700 overflow-hidden bg-[#0c1017]" id="chart-dow-average"></div>
              <Comments identifier="chart-dow-average" />
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <!-- Global Core Automation Script Integration Blocks -->
  <script>
    function updateChartsHeight() {
      const dynamicGrid = document.getElementById('dynamic-grid-container');
      if (!dynamicGrid) return;
      
      const chartContainers = dynamicGrid.querySelectorAll('.cryptowatch-frame-box');
      chartContainers.forEach(container => {
        // @ts-ignore
        container.style.height = "360px";
      });
    }

    function runSizingSequencerLoop() {
      updateChartsHeight();
      setTimeout(updateChartsHeight, 10);
      setTimeout(updateChartsHeight, 50);
      setTimeout(updateChartsHeight, 100);
      setTimeout(updateChartsHeight, 200);
      setTimeout(updateChartsHeight, 500);
      setTimeout(updateChartsHeight, 1000);
    }

    function buildDynamicGridMatrix() {
      const urlParams = new URLSearchParams(window.location.search);
      const cryptoQueryParam = urlParams.get('c');

      if (!cryptoQueryParam) return false;

      const tickerArray = cryptoQueryParam
        .split(',')
        .map((ticker) => ticker.trim().replace(/\/+$|^\s+|\s+$/g, ''))
        .filter(Boolean);
      if (tickerArray.length === 0) return false;

      document.getElementById('wsm-standard-workspace')?.classList.add('hidden');
      document.getElementById('cryptowatch-dynamic-workspace')?.classList.remove('hidden');
      
      const gridContainer = document.getElementById('dynamic-grid-container');
      if (!gridContainer) return false;
      gridContainer.innerHTML = ''; 

      tickerArray.forEach((ticker, idx) => {
        const elementUniqueId = `cryptowatch-node-frame-${idx}`;
        const cleanTicker = ticker.trim().replace(/\/+$|^\s+|\s+$/g, '');
        
        const cardNode = document.createElement('div');
        cardNode.className = "bg-[#0c1017] border border-gray-700 p-4 rounded-md flex flex-col justify-between";
        
        cardNode.innerHTML = `
          <div class="mb-2 flex justify-between items-center border-b border-gray-800 pb-1.5">
            <span class="font-bold text-xs text-blue-400 font-mono uppercase tracking-wide">${cleanTicker}</span>
            <span class="text-[10px] text-gray-500 font-mono">Live Matrix Stream</span>
          </div>
          <div id="${elementUniqueId}" style="width: 100%; height: 360px;" class="cryptowatch-frame-box rounded border border-gray-700 overflow-hidden bg-[#0c1017]"></div>
        `;
        gridContainer.appendChild(cardNode);

        // Mount chart objects instantly after node validation loop passes
        // @ts-ignore
        if (window.TradingView && window.TradingView.widget) {
          // @ts-ignore
          new window.TradingView.widget({
            "width": "100%",
            "height": "100%",
            "symbol": cleanTicker,
            "interval": "D",
            "timezone": "Etc/UTC",
            "theme": "dark",
            "style": "1",
            "locale": "en",
            "enable_publishing": false,
            "hide_side_toolbar": true,
            "allow_symbol_change": true,
            "container_id": elementUniqueId,
            "aff_id": "167679"
          });
        }
      });
      
      runSizingSequencerLoop();
      return true;
    }

    function renderMiniPrices() {
      const targets = document.querySelectorAll('.price-holder');
      targets.forEach((el, idx) => {
        const symbolStr = el.getAttribute('data-symbol');
        const nodeUniqueId = `quote-widget-${idx}`;
        const innerDiv = document.createElement('div');
        innerDiv.id = nodeUniqueId;
        el.appendChild(innerDiv);

        const tryRenderWidget = async (retries = 0) => {
          // @ts-ignore
          if (window.TradingView && window.TradingView.SingleQuoteWidget) {
            try {
              // @ts-ignore
              new window.TradingView.SingleQuoteWidget({
                symbol: symbolStr,
                width: "100%",
                colorTheme: "dark",
                isTransparent: true,
                locale: "en",
                container_id: nodeUniqueId
              });
              return;
            } catch (e) { return; }
          }

          const display = innerDiv;
          display.textContent = '…';
          try {
            const price = await fetchPriceForSymbol(symbolStr);
            if (price !== null) {
              display.textContent = formatPrice(price);
              return;
            }

            // Try Finnhub proxy first (requires FINNHUB_API_KEY), then generic proxy
            const fhRes = await fetch(`/api/price-finnhub?symbol=${encodeURIComponent(symbolStr)}`);
            if (fhRes.ok) {
              const j = await fhRes.json();
              if (j && j.price) { display.textContent = formatPrice(j.price); return; }
            }

            const proxyRes = await fetch(`/api/price?symbol=${encodeURIComponent(symbolStr)}`);
            if (proxyRes.ok) {
              const j2 = await proxyRes.json();
              if (j2 && j2.price) { display.textContent = formatPrice(j2.price); return; }
            }

            // Last resort: show a TradingView link with affiliate id so user can click through
            const tvSafe = symbolStr ? symbolStr.replace(':','-') : '';
            const tvUrl = `https://www.tradingview.com/symbols/${encodeURIComponent(tvSafe)}/?aff_id=167679`;
            display.innerHTML = `<a href="${tvUrl}" target="_blank" rel="noopener noreferrer" class="text-sm text-blue-400 underline">Open on TradingView</a>`;
          } catch (err) {
            if (retries < 8) setTimeout(() => tryRenderWidget(retries + 1), 300);
            else display.textContent = 'N/A';
          }
        };

        tryRenderWidget();
      });
    }

    function updateSummaryPrices() {
      const summaryMap = [
        { id: 'summary-price-btc', symbol: 'BINANCE:BTCUSDT' },
        { id: 'summary-price-eth', symbol: 'BINANCE:ETHUSDT' },
        { id: 'summary-price-nifty', symbol: 'NSE:NIFTY' },
        { id: 'summary-price-sp500', symbol: '^GSPC' },
        { id: 'summary-price-dow', symbol: 'TVC:DJI' }
      ];

      summaryMap.forEach(async (item) => {
        const el = document.getElementById(item.id);
        if (!el) return;
        el.textContent = '…';
        const price = await fetchPriceForSymbol(item.symbol);
        if (price !== null) {
          el.textContent = formatPrice(price);
          el.classList.add('text-emerald-400');
          el.classList.remove('text-gray-400');
          return;
        }

        const proxyRes = await fetch(`/api/price?symbol=${encodeURIComponent(item.symbol)}`);
        if (proxyRes.ok) {
          const j = await proxyRes.json();
          if (j && j.price !== null) {
            el.textContent = formatPrice(j.price);
            el.classList.add('text-emerald-400');
            el.classList.remove('text-gray-400');
            return;
          }
        }

        el.textContent = 'N/A';
        el.classList.remove('text-emerald-400');
        el.classList.add('text-gray-400');
      });
    }

